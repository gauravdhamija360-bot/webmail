<section style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); padding: 100px 5%; border-bottom: 1px solid #e1e8ed;">
    <div class="row text-center">
        <div class="col-md-8 col-md-offset-2">
            <h2 style="font-weight: 800; font-size: 38px; color: #1A73E8; margin-bottom: 10px;">Claim Your Digital Identity</h2>
            <p style="font-size: 18px; color: #555; margin-bottom: 40px;">Check if your preferred @{{serviceDomain}} address is still available.</p>
            
            <div class="input-group input-group-lg" style="max-width: 700px; margin: 0 auto; box-shadow: 0 15px 35px rgba(0,0,0,0.1); border-radius: 50px; overflow: hidden; background: white; padding: 5px;">
                <input type="text" id="usernameInput" class="form-control" placeholder="yourname" style="border: none; box-shadow: none; font-size: 24px; height: 70px; padding-left: 30px; font-weight: 600;">
                <span class="input-group-addon" style="background: white; border: none; font-size: 24px; color: #999; font-weight: 400; padding-right: 20px;">@{{serviceDomain}}</span>
                <span class="input-group-btn">
                    <button id="checkBtn" class="btn btn-primary" type="button" style="height: 70px; border-radius: 0 50px 50px 0; padding: 0 40px; font-weight: 800; background: #1A73E8; font-size: 18px;">
                        CHECK AVAILABILITY
                    </button>
                </span>
            </div>
            
            <div id="checkResult" style="margin-top: 25px; min-height: 30px; font-weight: 600; font-size: 18px; display: none;">
                </div>
        </div>
    </div>
</section>

<script>
document.getElementById('checkBtn').addEventListener('click', async function() {
    const username = document.getElementById('usernameInput').value.trim();
    const resultDiv = document.getElementById('checkResult');
    const checkBtn = this;

    if (!username || username.length < 3) {
        resultDiv.style.display = 'block';
        resultDiv.style.color = '#d93025';
        resultDiv.innerHTML = '<span class="glyphicon glyphicon-exclamation-sign"></span> Please enter at least 3 characters.';
        return;
    }

    // Visual feedback
    checkBtn.innerHTML = 'CHECKING...';
    checkBtn.disabled = true;
    resultDiv.style.display = 'none';

    try {
        /* NOTE: You need to create a route on your server /api/check-username 
           that calls WildDuck's GET /user/resolve?address=username@domain
        */
        const response = await fetch(`/api/check-username?username=${username}`);
        const data = await response.json();

        resultDiv.style.display = 'block';

        if (data.available) {
            resultDiv.style.color = '#34A853';
            resultDiv.innerHTML = `<span class="glyphicon glyphicon-ok-circle"></span> Good news! <strong>${username}@{{serviceDomain}}</strong> is available. 
                                   <br><br><a href="/purchase?username=${username}" class="btn btn-success" style="border-radius: 25px; padding: 10px 30px;">BUY NOW</a>`;
        } else {
            resultDiv.style.color = '#d93025';
            resultDiv.innerHTML = `<span class="glyphicon glyphicon-remove-circle"></span> Sorry, <strong>${username}</strong> is already taken. Try another?`;
        }
    } catch (err) {
        resultDiv.style.display = 'block';
        resultDiv.style.color = '#f4b400';
        resultDiv.innerHTML = 'Error checking availability. Please try again later.';
    } finally {
        checkBtn.innerHTML = 'CHECK AVAILABILITY';
        checkBtn.disabled = false;
    }
});
</script>








