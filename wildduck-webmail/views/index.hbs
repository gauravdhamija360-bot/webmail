<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --landing-ink: #132238;
        --landing-muted: #5f6f84;
        --landing-blue: #1d63d8;
        --landing-blue-deep: #0d47a1;
        --landing-sky: #d9ecff;
        --landing-cloud: #f5f9ff;
        --landing-surface: #ffffff;
        --landing-navy: #071a33;
        --landing-border: rgba(14, 42, 77, 0.08);
        --landing-success: #1f9d62;
        --landing-shadow: 0 24px 80px rgba(10, 38, 74, 0.12);
        --landing-shadow-soft: 0 14px 40px rgba(14, 42, 77, 0.08);
        --landing-radius: 30px;
        --landing-radius-sm: 18px;
        --landing-transition: all 0.28s ease;
    }

    body.home-page {
        font-family: 'Manrope', 'Inter', sans-serif;
        color: var(--landing-ink);
        background: #fff;
        line-height: 1.65;
    }

    .landing-shell {
        overflow: hidden;
    }

    .landing-section {
        padding: 96px 0;
        position: relative;
    }

    .landing-section.alt {
        background:
            radial-gradient(circle at top left, rgba(46, 117, 255, 0.08), transparent 36%),
            linear-gradient(180deg, #fbfdff 0%, #f4f9ff 100%);
    }

    .landing-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(29, 99, 216, 0.08);
        color: var(--landing-blue);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .landing-section-title {
        font-size: clamp(2.2rem, 3.3vw, 3.4rem);
        line-height: 1.08;
        letter-spacing: -0.04em;
        font-weight: 800;
        margin: 20px 0 16px;
    }

    .landing-section-copy {
        font-size: 1.12rem;
        color: var(--landing-muted);
        max-width: 720px;
        margin: 0 auto;
    }

    .hero-wrapper {
        padding: 136px 0 108px;
        background:
            radial-gradient(circle at 12% 20%, rgba(115, 181, 255, 0.18), transparent 30%),
            radial-gradient(circle at 88% 18%, rgba(37, 112, 237, 0.16), transparent 28%),
            linear-gradient(180deg, #f8fbff 0%, #ffffff 58%);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
        gap: 48px;
        align-items: center;
    }

    .hero-title {
        font-size: clamp(3rem, 5.6vw, 5.6rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
        font-weight: 800;
        margin: 22px 0 24px;
    }

    .hero-title span {
        color: var(--landing-blue);
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: var(--landing-muted);
        max-width: 720px;
        margin-bottom: 34px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin: 22px 0 28px;
    }

    .hero-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 54px;
        padding: 0 24px;
        border-radius: 999px;
        font-weight: 800;
        text-decoration: none !important;
        transition: var(--landing-transition);
    }

    .hero-action.primary {
        background: var(--landing-blue);
        color: #fff;
        box-shadow: 0 18px 35px rgba(29, 99, 216, 0.22);
    }

    .hero-action.primary:hover {
        background: var(--landing-blue-deep);
        color: #fff;
        transform: translateY(-2px);
    }

    .hero-action.secondary {
        border: 1px solid rgba(19, 34, 56, 0.12);
        color: var(--landing-ink);
        background: rgba(255, 255, 255, 0.82);
    }

    .hero-action.secondary:hover {
        border-color: rgba(29, 99, 216, 0.28);
        color: var(--landing-blue);
        transform: translateY(-2px);
    }

    .hero-microproof {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        margin-top: 8px;
        color: var(--landing-muted);
        font-size: 0.96rem;
        font-weight: 600;
    }

    .hero-microproof span {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .hero-microproof i {
        color: var(--landing-success);
    }

    .domain-search {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(19, 34, 56, 0.08);
        box-shadow: var(--landing-shadow);
    }

    .domain-search input {
        width: 100%;
        min-width: 0;
        border: none;
        outline: none;
        background: transparent;
        font-size: 1.7rem;
        font-weight: 800;
        line-height: 1.2;
        color: var(--landing-ink);
        padding: 0 18px;
    }

    .domain-search input::placeholder {
        color: #9aa8ba;
        font-weight: 700;
    }

    .domain-ext {
        color: #8393a8;
        font-size: 1.45rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        white-space: nowrap;
    }

    .btn-search {
        min-height: 58px;
        border: none;
        padding: 0 28px;
        border-radius: 18px;
        background: linear-gradient(135deg, var(--landing-blue) 0%, #267df3 100%);
        color: #fff;
        font-weight: 800;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: var(--landing-transition);
    }

    .btn-search:hover,
    .btn-search:focus {
        background: linear-gradient(135deg, #1359c8 0%, #1d63d8 100%);
        color: #fff;
        transform: translateY(-1px);
    }

    .btn-search[disabled] {
        cursor: wait;
        opacity: 0.8;
    }

    .check-result {
        min-height: 62px;
        margin-top: 18px;
        display: flex;
        align-items: center;
    }

    .availability-card,
    .availability-error,
    .availability-neutral {
        width: 100%;
        border-radius: 18px;
        padding: 16px 18px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 14px;
        font-weight: 700;
    }

    .availability-card {
        background: #ecf9f2;
        border: 1px solid rgba(31, 157, 98, 0.18);
        color: #137247;
    }

    .availability-error {
        background: #fff3f2;
        border: 1px solid rgba(201, 54, 44, 0.15);
        color: #bf3d35;
    }

    .availability-neutral {
        background: #f4f8fd;
        border: 1px solid rgba(19, 34, 56, 0.08);
        color: var(--landing-muted);
    }

    .availability-card .claim-link {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #137247;
        text-decoration: none;
        font-weight: 800;
    }

    .availability-card .claim-link:hover {
        color: #0f5e3b;
    }

    .hero-sidecard {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(19, 34, 56, 0.08);
        border-radius: 34px;
        padding: 30px;
        box-shadow: var(--landing-shadow);
        position: relative;
        overflow: hidden;
    }

    .hero-sidecard::before {
        content: "";
        position: absolute;
        inset: -50px -30px auto auto;
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(79, 203, 255, 0.34), transparent 70%);
        pointer-events: none;
    }

    .hero-sidecard-panel {
        border-radius: 24px;
        background: linear-gradient(180deg, #0a1b33 0%, #10284b 100%);
        color: #fff;
        padding: 24px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .hero-sidecard-label {
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.62);
        font-weight: 800;
    }

    .hero-sidecard-address {
        margin-top: 14px;
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .hero-sidecard-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    .hero-sidecard-stat {
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.08);
        padding: 16px;
    }

    .hero-sidecard-stat strong {
        display: block;
        font-size: 1.18rem;
        margin-bottom: 4px;
    }

    .hero-sidecard-stat span {
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.68);
    }

    .value-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
        margin-top: 36px;
    }

    .value-pill {
        background: rgba(255, 255, 255, 0.84);
        border: 1px solid rgba(19, 34, 56, 0.06);
        border-radius: 22px;
        padding: 18px 20px;
        box-shadow: var(--landing-shadow-soft);
    }

    .value-pill strong {
        display: block;
        font-size: 1.25rem;
        margin-bottom: 4px;
    }

    .value-pill span {
        color: var(--landing-muted);
        font-size: 0.95rem;
    }

    .story-grid,
    .feature-grid,
    .setup-grid,
    .faq-grid {
        display: grid;
        gap: 24px;
    }

    .story-grid {
        grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
        align-items: center;
    }

    .feature-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 46px;
    }

    .feature-card,
    .setup-card,
    .faq-card,
    .story-card,
    .security-card,
    .pricing-card {
        background: var(--landing-surface);
        border: 1px solid var(--landing-border);
        border-radius: 28px;
        box-shadow: var(--landing-shadow-soft);
    }

    .feature-card {
        padding: 30px;
        transition: var(--landing-transition);
        height: 100%;
    }

    .feature-card:hover,
    .setup-card:hover,
    .pricing-card:hover,
    .faq-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(13, 50, 95, 0.12);
    }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ebf4ff;
        color: var(--landing-blue);
        font-size: 24px;
        margin-bottom: 20px;
    }

    .feature-card h3,
    .setup-card h3,
    .pricing-card h3,
    .faq-card h3,
    .story-card h3,
    .security-card h3 {
        margin: 0 0 12px;
        font-size: 1.45rem;
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .feature-card p,
    .setup-card p,
    .pricing-card p,
    .faq-card p,
    .story-card p,
    .security-card p {
        color: var(--landing-muted);
        margin: 0;
    }

    .story-card {
        padding: 34px;
    }

    .story-list {
        list-style: none;
        padding: 0;
        margin: 26px 0 0;
    }

    .story-list li {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        margin-bottom: 16px;
        color: var(--landing-muted);
        font-weight: 600;
    }

    .story-list i {
        color: var(--landing-success);
        margin-top: 4px;
    }

    .story-visual {
        background: linear-gradient(180deg, #0a1b33 0%, #0d274c 100%);
        border-radius: 34px;
        padding: 34px;
        color: #fff;
        position: relative;
        overflow: hidden;
        min-height: 420px;
        box-shadow: var(--landing-shadow);
    }

    .story-visual::after {
        content: "";
        position: absolute;
        right: -55px;
        bottom: -55px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(79, 203, 255, 0.24), transparent 68%);
    }

    .story-window {
        position: relative;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 24px;
        backdrop-filter: blur(6px);
    }

    .story-single-visual img {
        width: 100%;
        height: 100%;
        min-height: 360px;
        object-fit: cover;
        border-radius: 18px;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.25);
    }

    .story-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
    }

    .story-tags span {
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.88);
        font-size: 0.86rem;
        font-weight: 700;
    }

    .security-block {
        background: linear-gradient(135deg, #06172d 0%, #0c2748 55%, #10335d 100%);
        border-radius: 38px;
        padding: 56px;
        color: #fff;
        overflow: hidden;
        position: relative;
    }

    .security-block::before {
        content: "";
        position: absolute;
        top: -80px;
        right: -30px;
        width: 240px;
        height: 240px;
        background: radial-gradient(circle, rgba(79, 203, 255, 0.24), transparent 68%);
    }

    .security-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 28px;
        align-items: start;
        position: relative;
        z-index: 1;
    }

    .security-copy p {
        color: rgba(255, 255, 255, 0.76);
        font-size: 1.08rem;
        max-width: 680px;
    }

    .security-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        margin-top: 34px;
    }

    .security-card {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.08);
        padding: 24px;
        box-shadow: none;
    }

    .security-card p {
        color: rgba(255, 255, 255, 0.68);
    }

    .security-rail {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 28px;
        padding: 26px;
    }

    .security-rail-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        font-weight: 700;
    }

    .security-rail-item:last-child {
        border-bottom: none;
    }

    .security-rail-item span:last-child {
        color: #9de8ff;
    }

    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 26px;
        margin-top: 44px;
    }

    .pricing-card {
        padding: 34px;
        position: relative;
    }

    .pricing-card.featured {
        background: linear-gradient(180deg, #0f4fb3 0%, #1c67df 100%);
        color: #fff;
        border-color: transparent;
        transform: translateY(-10px);
        box-shadow: 0 28px 60px rgba(28, 103, 223, 0.3);
    }

    .pricing-card.featured p,
    .pricing-card.featured li {
        color: rgba(255, 255, 255, 0.8);
    }

    .pricing-tag {
        display: inline-flex;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(19, 34, 56, 0.06);
        color: var(--landing-muted);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .pricing-card.featured .pricing-tag {
        background: rgba(255, 255, 255, 0.14);
        color: #fff;
    }

    .price-line {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        margin: 20px 0;
    }

    .price-line strong {
        font-size: 3.3rem;
        line-height: 1;
        letter-spacing: -0.05em;
    }

    .price-line span {
        color: var(--landing-muted);
        font-weight: 700;
        padding-bottom: 8px;
    }

    .pricing-card.featured .price-line span {
        color: rgba(255, 255, 255, 0.7);
    }

    .pricing-list {
        list-style: none;
        padding: 0;
        margin: 28px 0 0;
    }

    .pricing-list li {
        display: flex;
        gap: 12px;
        margin-bottom: 14px;
        color: var(--landing-muted);
        font-weight: 600;
    }

    .pricing-list i {
        color: var(--landing-success);
        margin-top: 4px;
    }

    .pricing-card.featured .pricing-list i {
        color: #c8f4ff;
    }

    .pricing-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 26px;
        min-height: 52px;
        border-radius: 999px;
        padding: 0 22px;
        text-decoration: none !important;
        font-weight: 800;
        transition: var(--landing-transition);
    }

    .pricing-action.primary {
        background: #fff;
        color: var(--landing-blue);
    }

    .pricing-action.secondary {
        background: #f0f6ff;
        color: var(--landing-blue);
    }

    .pricing-action:hover {
        transform: translateY(-2px);
    }

    .setup-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin-top: 42px;
    }

    .audience-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
        margin-top: 46px;
    }

    .audience-card {
        background: #fff;
        border: 1px solid var(--landing-border);
        border-radius: 28px;
        overflow: hidden;
        box-shadow: var(--landing-shadow-soft);
        transition: var(--landing-transition);
    }

    .audience-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(13, 50, 95, 0.12);
    }

    .audience-card img {
        width: 100%;
        height: 240px;
        object-fit: cover;
        display: block;
    }

    .audience-card-body {
        padding: 24px;
    }

    .audience-card-body h3 {
        margin: 0 0 10px;
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .audience-card-body p {
        margin: 0;
        color: var(--landing-muted);
    }

    .setup-card {
        padding: 30px;
        height: 100%;
        transition: var(--landing-transition);
    }

    .server-table {
        width: 100%;
        margin-top: 24px;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .server-table td {
        padding: 14px 16px;
        background: #f7faff;
    }

    .server-table td:first-child {
        width: 42%;
        border-radius: 12px 0 0 12px;
        color: var(--landing-muted);
        font-weight: 800;
    }

    .server-table td:last-child {
        border-radius: 0 12px 12px 0;
        color: var(--landing-blue);
        font-family: "SFMono-Regular", Consolas, monospace;
        font-weight: 700;
        word-break: break-word;
    }

    .encryption-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 999px;
        background: #e8f7ee;
        color: #157448;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .setup-note {
        margin-top: 30px;
        border-radius: 24px;
        background: linear-gradient(180deg, #f7fbff 0%, #eef6ff 100%);
        border: 1px dashed rgba(29, 99, 216, 0.25);
        padding: 28px;
        color: var(--landing-muted);
    }

    .setup-note strong {
        color: var(--landing-blue);
    }

    .faq-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        margin-top: 44px;
    }

    .faq-card {
        padding: 28px;
        height: 100%;
        transition: var(--landing-transition);
    }

    .landing-cta-band {
        background: linear-gradient(135deg, #081a32 0%, #0d2850 60%, #134178 100%);
        border-radius: 36px;
        padding: 58px;
        color: #fff;
        box-shadow: var(--landing-shadow);
    }

    .landing-cta-band p {
        color: rgba(255, 255, 255, 0.76);
        font-size: 1.08rem;
        max-width: 620px;
        margin: 18px auto 0;
    }

    .landing-cta-links {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
    }

    .landing-inline-link {
        color: var(--landing-blue);
        font-weight: 800;
        text-decoration: none;
    }

    .landing-inline-link:hover {
        color: var(--landing-blue-deep);
    }

    @media (max-width: 1199px) {
        .hero-grid,
        .story-grid,
        .security-grid {
            grid-template-columns: 1fr;
        }

        .value-strip {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 991px) {
        .feature-grid,
        .audience-grid,
        .pricing-grid,
        .setup-grid,
        .faq-grid,
        .security-list {
            grid-template-columns: 1fr;
        }

        .security-block,
        .landing-cta-band {
            padding: 36px 26px;
        }

        .pricing-card.featured {
            transform: none;
        }
    }

    @media (max-width: 767px) {
        .landing-section {
            padding: 78px 0;
        }

        .hero-wrapper {
            padding: 122px 0 88px;
        }

        .domain-search {
            grid-template-columns: 1fr;
            border-radius: 24px;
        }

        .domain-search input,
        .domain-ext {
            text-align: center;
        }

        .domain-search input {
            font-size: 1.45rem;
        }

        .domain-ext {
            font-size: 1.24rem;
        }

        .check-result {
            min-height: 76px;
