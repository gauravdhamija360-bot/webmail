<script>
const usernameInput = document.getElementById('usernameInput');
const checkBtn = document.getElementById('checkBtn');
const checkResult = document.getElementById('checkResult');
const usernamePattern = /^[a-z0-9][a-z0-9.-]*$/i;

function renderResult(type, html) {
    const className = type === 'success'
        ? 'availability-card'
        : type === 'error'
            ? 'availability-error'
            : 'availability-neutral';

    checkResult.innerHTML = `<div class="${className}">${html}</div>`;
}

async function checkUsernameAvailability() {
    const username = usernameInput.value.trim().toLowerCase();

    usernameInput.value = username;

    if (!username || username.length < 3) {
        renderResult('error', '<i class="fa-solid fa-circle-exclamation"></i><span>Username must be at least 3 characters.</span>');
        return;
    }

    if (!usernamePattern.test(username)) {
        renderResult('error', '<i class="fa-solid fa-circle-exclamation"></i><span>Use only letters, numbers, dots, and hyphens.</span>');
        return;
    }

    checkBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Checking';
    checkBtn.disabled = true;

    try {
        const response = await fetch(`/check-username?username=${encodeURIComponent(username)}`);
        const data = await response.json();

        if (!response.ok) {
            renderResult('error', `<i class="fa-solid fa-triangle-exclamation"></i><span>${data.error || 'Unable to check username right now.'}</span>`);
            return;
        }

        if (data.available) {
            renderResult(
                'success',
                `<i class="fa-solid fa-circle-check"></i><span><strong>${username}@{{serviceDomain}}</strong> is available and ready to claim.</span><a class="claim-link" href="/purchase?username=${encodeURIComponent(username)}" data-analytics-event="start_checkout" data-analytics-category="conversion" data-analytics-label="username_available_continue">Continue <i class="fa-solid fa-arrow-right"></i></a>`
            );
            return;
        }

        renderResult('error', '<i class="fa-solid fa-circle-xmark"></i><span>That name is already taken. Try a variation with a dot or extra word.</span>');
    } catch (err) {
        renderResult('error', '<i class="fa-solid fa-wifi"></i><span>Connection error. Please try again.</span>');
    } finally {
        checkBtn.innerHTML = 'Check Availability';
        checkBtn.disabled = false;
    }
}

usernameInput.addEventListener('input', function () {
    this.value = this.value.replace(/[^a-z0-9.-]/gi, '');
});

usernameInput.addEventListener('keydown', function (event) {
    if (event.key === 'Enter') {
        event.preventDefault();
        checkUsernameAvailability();
    }
});

checkBtn.addEventListener('click', checkUsernameAvailability);
</script>
