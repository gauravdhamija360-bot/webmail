        border: none;
        padding: 20px 45px;
        border-radius: var(--radius-pill);
        font-weight: 800;
        cursor: pointer;
        transition: var(--transition);
        text-transform: uppercase;
        font-size: 14px;
    }

    .btn-search:hover { background: var(--primary-dark); transform: scale(1.03); }

    /* --- Features Grid --- */
    .section-padding { padding: 100px 0; }

    .feature-card {
        padding: 50px 35px;
        border-radius: var(--radius-lg);
        background: #fff;
        border: 1px solid #f0f0f0;
        transition: var(--transition);
        height: 100%;
    }

    .feature-card:hover { transform: translateY(-12px); box-shadow: var(--shadow-soft); border-color: var(--primary-soft); }

    .icon-box {
        width: 70px;
        height: 70px;
        background: #f1f6ff;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 30px;
        font-size: 30px;
        color: var(--primary);
    }

    /* --- Security Shield Section --- */
    .security-section {
        background: #041E42;
        color: #fff;
        border-radius: 40px;
        margin: 0 20px;
        padding: 100px 60px;
        position: relative;
        overflow: hidden;
    }

    .security-shield-bg {
        position: absolute;
        right: -5%;
        top: 50%;
        transform: translateY(-50%);
        font-size: 400px;
        opacity: 0.05;
        color: #fff;
    }

    /* --- Pricing --- */
    .pricing-card {
        background: #fff;
        border-radius: 30px;
        padding: 60px 40px;
        border: 1px solid #eee;
        transition: var(--transition);
