<!DOCTYPE html>
<html lang="en">

<head>
    {{>header}}
    <style>
        /* 1. Global Reset - Eliminates the "Ghost Margin" */
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
            background-color: #ffffff;
            -webkit-font-smoothing: antialiased;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            /* 🚀 SPACE FOR THE FIXED NAV: Matches the 85px navbar height */
            padding-top: 0px !important; 
        }

        /* 2. Navbar Absolute Reset */
        .navbar-fixed-top {
            top: 0 !important;
            margin: 0 !important;
            border-top: none !important;
            width: 100%;
        }

        /* 3. Main Content Wrapper */
        .main-content-wrapper {
            width: 100%;
            padding: 0;
            margin: 0;
            display: block;
            position: relative;
        }

        /* 4. Flash Messages (Floating below the Blur) */
        .flash-messages {
            position: fixed;
            top: 100px;
            right: 30px;
            z-index: 10001;
            min-width: 320px;
        }

        /* 5. Sharp Edge Branding */
        .alert, .btn, .modal-content, .dropdown-menu, .form-control {
            border-radius: 0 !important;
        }

        

        /* Utility: Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #1A73E8; }
        ::-webkit-scrollbar-thumb:hover { background: #0D47A1; }

        .alert-animate {
            animation: slideDownFade 0.5s ease forwards;
        }

        @keyframes slideDownFade {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body{{#if user}} class="is-logged-in"{{/if}}{{#if isHome}} class="home-page"{{/if}}>

    {{>navbar}}

    <div class="flash-messages">
        {{flash_messages}}
    </div>

    <div class="main-content-wrapper">

        {{#if generalNotification}}
        <div class="container-fluid alert-animate" style="padding: 0; margin-bottom: 0;">
            <div class="alert alert-info alert-dismissible" role="alert" style="background: #1A73E8; color: white; border: none; padding: 25px 5%; margin: 0;">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="color: white; opacity: 1; top: 18px; right: 5%;">
                    <span aria-hidden="true">&times;</span>
                </button>
                <div style="display: flex; align-items: center; justify-content: center;">
                    <span class="glyphicon glyphicon-bullhorn" style="margin-right: 15px; font-size: 20px;"></span> 
                    <span style="font-weight: 600; font-size: 16px;">{{{generalNotification}}}</span>
                </div>
            </div>
        </div>
        {{/if}}

        {{{body}}}

    </div>

    <footer class="mega-footer">
    <div class="container">
        <div class="row">
            <div class="col-md-4 brand-column">
                <img src="/images/yoover-logo-white.svg" alt="Yoover" class="footer-logo">
                <p class="brand-description">
                    Engineering a private future through decentralized architecture and zero-compromise, triple-sided encryption. Your privacy is not a feature, it's a human right.
                </p>
                <div class="status-indicator-footer">
                    <span class="status-dot"></span>
                    <span class="status-text">SYSTEMS OPERATIONAL: 100% UP-TIME</span>
                </div>
                <div class="social-icons">
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin"></i></a>
                    <a href="#"><i class="fa-brands fa-github"></i></a>
                </div>
            </div>

            <div class="col-md-2 col-sm-4 col-xs-6">
                <h4>PRODUCT</h4>
                <ul class="footer-links">
                    <li><a href="/features">Features</a></li>
                    <li><a href="/security">Security Shield</a></li>
                    <li><a href="/pricing">Pricing Plans</a></li>
                    <li><a href="/api">Developer API</a></li>
                    <li><a href="/migration">Migration Tool</a></li>
                </ul>
            </div>

            <div class="col-md-2 col-sm-4 col-xs-6">
                <h4>SUPPORT</h4>
                <ul class="footer-links">
                    <li><a href="/help">Help Center</a></li>
                    <li><a href="#setup-details">Setup Guide</a></li>
                    <li><a href="/contact">Contact Support</a></li>
                    <li><a href="/status">System Status</a></li>
                    <li><a href="/help#faq">FAQ</a></li>
                </ul>
            </div>

            <div class="col-md-4 col-sm-12">
                <div class="newsletter-box">
                    <h4>Stay Updated</h4>
                    <p>Get privacy tips and platform updates delivered to your secure inbox.</p>
                    <div class="newsletter-input-group">
                        <input type="email" placeholder="email@example.com" aria-label="Email address">
                        <button type="button">JOIN</button>
                    </div>
                </div>
                <div class="mini-security-badges">
                    <span><i class="fa-solid fa-shield-halved"></i> TLS 1.3</span>
                    <span><i class="fa-solid fa-lock"></i> AES-256</span>
                </div>
            </div>
        </div>

        <hr class="footer-divider">

        <div class="row footer-bottom">
            <div class="col-md-6 col-sm-12">
                <p class="copyright">
                    &copy; 2026 <strong>{{serviceName}}</strong>. Authenticated via <span class="highlight">{{serviceDomain}}</span>
                </p>
            </div>
            <div class="col-md-6 col-sm-12 text-right-md">
                <ul class="list-inline legal-links">
                    <li><a href="/privacy">Privacy Policy</a></li>
                    <li><a href="/terms">Terms of Service</a></li>
                    <li><a href="/cookies">Cookie Policy</a></li>
                </ul>
            </div>
        </div>
    </div>
</footer>

<style>
    /* --- MEGA FOOTER STYLES --- */
    .mega-footer {
        background: #041E42; /* Deep Navy to match your elite theme */
        color: #ffffff;
        padding: 100px 0 40px;
        font-family: 'Inter', sans-serif;
    }

    .brand-column { margin-bottom: 40px; }

    .footer-logo {
        height: 40px;
        margin-bottom: 25px;
        filter: brightness(0) invert(1);
    }

    .brand-description {
        color: rgba(255, 255, 255, 0.6);
        padding-right: 40px;
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 25px;
    }

    /* Status Dot Animation */
    .status-indicator-footer {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        padding: 6px 12px;
        border-radius: 4px;
        margin-bottom: 20px;
    }
    .status-dot {
        height: 7px; width: 7px;
        background-color: #34A853;
        border-radius: 50%;
        margin-right: 10px;
        box-shadow: 0 0 8px #34A853;
        animation: pulseStatus 2s infinite;
    }
    .status-text {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.8);
    }

    @keyframes pulseStatus {
        0% { opacity: 1; }
        50% { opacity: 0.4; }
        100% { opacity: 1; }
    }

    .social-icons a {
        font-size: 18px;
        margin-right: 20px;
        color: rgba(255, 255, 255, 0.5);
        transition: 0.3s;
    }
    .social-icons a:hover { color: #1A73E8; transform: translateY(-3px); display: inline-block; }

    /* Links */
    .mega-footer h4 {
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 30px;
        color: #fff;
    }

    .footer-links { list-style: none; padding: 0; }
    .footer-links li { margin-bottom: 15px; }
    .footer-links a {
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none !important;
        font-size: 14px;
        transition: 0.3s;
    }
    .footer-links a:hover { color: #fff; padding-left: 5px; }

    /* Newsletter Box */
    .newsletter-box {
        background: rgba(255, 255, 255, 0.04);
        padding: 30px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .newsletter-box p { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 20px; }
    
    .newsletter-input-group { display: flex; }
    .newsletter-input-group input {
        flex: 1;
        padding: 12px 15px;
        background: #fff;
        border: none;
        border-radius: 8px 0 0 8px;
        outline: none;
        color: #333;
    }
    .newsletter-input-group button {
        background: #1A73E8;
        color: #fff;
        border: none;
        padding: 0 20px;
        border-radius: 0 8px 8px 0;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
    }
    .newsletter-input-group button:hover { background: #1557b0; }

    .mini-security-badges { margin-top: 20px; display: flex; gap: 20px; }
    .mini-security-badges span {
        font-size: 10px;
        font-weight: 700;
        color: rgba(255,255,255,0.3);
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .mini-security-badges i { color: #1A73E8; margin-right: 5px; }

    /* Bottom Bar */
    .footer-divider { border-color: rgba(255, 255, 255, 0.08); margin: 0px 0 30px; }
    .copyright { font-size: 12px; color: rgba(255, 255, 255, 0.3); }
    .highlight { color: #1A73E8; font-weight: 700; }
    
    .legal-links a { color: rgba(255, 255, 255, 0.3); font-size: 12px; margin-left: 20px; text-decoration: none; }
    .legal-links a:hover { color: #fff; }

    /* Responsive */
    @media (max-width: 991px) {
        .text-right-md { text-align: center; margin-top: 20px; }
        .footer-bottom { text-align: center; }
        .legal-links a { margin: 0 10px; }
    }
</style>