<style>
    /* --- MEGA FOOTER STYLES --- */
    .mega-footer {
        background: #041E42; /* Deep Navy to match your elite theme */
        color: #ffffff;
        padding: 100px 0 40px;
        font-family: 'Inter', sans-serif;
    }

    .brand-column { margin-bottom: 40px; }

    .footer-logo {
        height: 40px;
        margin-bottom: 25px;
    }

    .brand-description {
        color: rgba(255, 255, 255, 0.6);
        padding-right: 40px;
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 25px;
    }

    /* Status Dot Animation */
    .status-indicator-footer {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        padding: 6px 12px;
        border-radius: 4px;
        margin-bottom: 20px;
    }
    .status-dot {
        height: 7px; width: 7px;
        background-color: #34A853;
        border-radius: 50%;
        margin-right: 10px;
        box-shadow: 0 0 8px #34A853;
        animation: pulseStatus 2s infinite;
    }
    .status-text {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.8);
