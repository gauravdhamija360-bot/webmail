<style>
    :root {
        --help-ink: #132238;
        --help-muted: #617286;
        --help-blue: #1d63d8;
        --help-blue-deep: #0d47a1;
        --help-sky: #eef6ff;
        --help-surface: #ffffff;
        --help-border: rgba(13, 42, 77, 0.08);
        --help-success: #1f9d62;
        --help-warn: #b46a0b;
        --help-navy: #071a33;
        --help-shadow: 0 18px 50px rgba(14, 42, 77, 0.08);
        --help-shadow-soft: 0 10px 30px rgba(14, 42, 77, 0.06);
    }

    .help-shell {
        padding: 128px 0 96px;
        background:
            radial-gradient(circle at 12% 8%, rgba(76, 152, 255, 0.12), transparent 24%),
            linear-gradient(180deg, #f8fbff 0%, #ffffff 42%);
        color: var(--help-ink);
    }

    .help-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.95fr);
        gap: 28px;
        align-items: stretch;
        margin-bottom: 38px;
    }

    .help-hero-card,
    .help-summary-card,
    .help-config-card,
    .help-guide-card,
    .help-troubleshoot-card,
    .help-support-card,
    .help-security-card {
        background: var(--help-surface);
        border: 1px solid var(--help-border);
        border-radius: 30px;
        box-shadow: var(--help-shadow-soft);
    }

    .help-hero-card {
        padding: 38px;
    }

    .help-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(29, 99, 216, 0.08);
        color: var(--help-blue);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.14em;
    }

    .help-hero-title {
        margin: 20px 0 16px;
        font-size: clamp(2.4rem, 4vw, 3.8rem);
        line-height: 1.04;
        letter-spacing: -0.05em;
        font-weight: 800;
    }

    .help-hero-copy {
        font-size: 1.12rem;
        line-height: 1.75;
        color: var(--help-muted);
        max-width: 760px;
    }

    .help-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 28px;
    }

    .help-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 52px;
        border-radius: 999px;
        padding: 0 22px;
        font-weight: 800;
        text-decoration: none !important;
        transition: all 0.25s ease;
    }

    .help-btn.primary {
        background: linear-gradient(135deg, var(--help-blue) 0%, #2b7df0 100%);
        color: #fff;
        box-shadow: 0 16px 34px rgba(29, 99, 216, 0.2);
    }

    .help-btn.primary:hover {
        color: #fff;
        background: linear-gradient(135deg, #1459c4 0%, var(--help-blue) 100%);
        transform: translateY(-1px);
    }

    .help-btn.secondary {
        background: #f4f8fd;
        color: var(--help-ink);
        border: 1px solid var(--help-border);
    }

    .help-btn.secondary:hover {
        color: var(--help-blue);
        border-color: rgba(29, 99, 216, 0.18);
        transform: translateY(-1px);
    }

    .help-summary-card {
        padding: 28px;
        background: linear-gradient(180deg, #081a32 0%, #0d274c 100%);
        color: #fff;
        box-shadow: 0 24px 60px rgba(7, 26, 51, 0.18);
    }

    .help-summary-card h3 {
        margin: 0 0 18px;
        font-size: 1.45rem;
        font-weight: 800;
    }

    .help-summary-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .help-summary-list li {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 14px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.09);
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
    }

    .help-summary-list li:last-child {
        border-bottom: none;
    }

    .help-summary-list i {
        color: #96e8ff;
        margin-top: 4px;
    }

    .help-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 24px;
    }

    .help-stack {
        display: grid;
        gap: 24px;
    }

    .help-config-card,
    .help-guide-card,
    .help-troubleshoot-card,
    .help-support-card,
    .help-security-card {
        padding: 30px;
    }

    .help-card-title {
        margin: 0 0 12px;
        font-size: 1.55rem;
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .help-card-copy {
        margin: 0 0 24px;
        color: var(--help-muted);
        line-height: 1.7;
    }

    .help-protocol-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 22px;
    }

    .help-protocol {
        border-radius: 22px;
        padding: 22px;
        background: #f8fbff;
        border: 1px solid rgba(29, 99, 216, 0.08);
    }

    .help-protocol-label {
        display: inline-flex;
        margin-bottom: 16px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(29, 99, 216, 0.1);
        color: var(--help-blue);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .help-protocol h4 {
        margin: 0 0 14px;
        font-size: 1.28rem;
        font-weight: 800;
    }

    .help-protocol dl {
        margin: 0;
    }

    .help-protocol dt {
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #7b8a9b;
        margin-top: 12px;
        font-weight: 800;
    }

    .help-protocol dd {
        margin: 4px 0 0;
        color: var(--help-ink);
        font-weight: 700;
        word-break: break-word;
    }

    .help-protocol dd small {
        color: var(--help-muted);
        font-weight: 600;
    }

    .help-note {
        border-radius: 20px;
        padding: 18px 20px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        line-height: 1.65;
        font-weight: 600;
    }

    .help-note.info {
        background: #f4f8fd;
        border: 1px solid rgba(13, 42, 77, 0.08);
        color: var(--help-muted);
    }

    .help-note.warn {
        background: #fff8ee;
        border: 1px solid rgba(180, 106, 11, 0.16);
        color: #7d5a1a;
    }

    .help-note i {
        margin-top: 4px;
        color: var(--help-blue);
    }

    .help-note.warn i {
        color: var(--help-warn);
    }

    .help-guide-list,
    .help-troubleshoot-list,
    .help-security-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .help-guide-list li,
    .help-troubleshoot-list li,
    .help-security-list li {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 16px 0;
        border-bottom: 1px solid rgba(13, 42, 77, 0.08);
    }

    .help-guide-list li:last-child,
    .help-troubleshoot-list li:last-child,
    .help-security-list li:last-child {
        border-bottom: none;
    }

    .help-step-number,
    .help-bullet {
        flex: 0 0 auto;
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        background: #ebf4ff;
        color: var(--help-blue);
    }

    .help-list-copy strong {
        display: block;
        margin-bottom: 4px;
        color: var(--help-ink);
    }

    .help-list-copy span {
        display: block;
        color: var(--help-muted);
        line-height: 1.7;
    }

    .help-support-card {
        background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
    }

    .help-support-links {
        display: grid;
        gap: 12px;
        margin-top: 18px;
    }

    .help-support-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 18px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(13, 42, 77, 0.08);
        text-decoration: none !important;
        color: var(--help-ink);
        font-weight: 700;
        transition: all 0.25s ease;
    }

    .help-support-link:hover {
        border-color: rgba(29, 99, 216, 0.16);
        color: var(--help-blue);
        transform: translateY(-1px);
    }

    .help-inline-code {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 8px;
        background: #f2f7fd;
        color: var(--help-blue);
        font-family: "SFMono-Regular", Consolas, monospace;
        font-size: 0.94em;
    }

    @media (max-width: 1199px) {
        .help-hero,
        .help-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 991px) {
        .help-protocol-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 767px) {
        .help-shell {
            padding: 118px 0 72px;
        }

        .help-hero-card,
        .help-summary-card,
        .help-config-card,
        .help-guide-card,
        .help-troubleshoot-card,
        .help-support-card,
        .help-security-card {
            padding: 24px;
            border-radius: 24px;
        }

        .help-hero-actions {
            flex-direction: column;
        }

        .help-btn {
            width: 100%;
        }
    }
</style>

<div class="help-shell">
    <div class="container">
        <div class="help-hero">
            <section class="help-hero-card">
                <div class="help-eyebrow">Support & Setup</div>
                <h1 class="help-hero-title">Everything you need to connect, secure, and troubleshoot your Yoover mailbox.</h1>
                <p class="help-hero-copy">
                    This page brings together the practical details that matter after signup: which server names to use, how to configure Apple Mail, Outlook, Thunderbird, iPhone, and Android, what to do when login fails, and how two-factor authentication affects mail apps.
                </p>
                <div class="help-hero-actions">
                    <a href="#account-setup" class="help-btn primary">View Setup Details</a>
                    <a href="/contact" class="help-btn secondary">Contact Support</a>
                </div>
            </section>

            <aside class="help-summary-card">
                <h3>Quick answer panel</h3>
                <ul class="help-summary-list">
                    <li><i class="fa-solid fa-circle-check"></i><span>Use your full email address as the login name in mail apps.</span></li>
                    <li><i class="fa-solid fa-circle-check"></i><span>IMAP is best if you want all devices to stay in sync.</span></li>
                    <li><i class="fa-solid fa-circle-check"></i><span>SMTP authentication is required for sending mail.</span></li>
                    <li><i class="fa-solid fa-circle-check"></i><span>If 2FA is enabled, use app-specific passwords for IMAP, POP3, and SMTP.</span></li>
                </ul>
            </aside>
        </div>

        <div class="help-grid">
            <div class="help-stack">
                <section class="help-config-card" id="account-setup">
                    <h2 class="help-card-title">Mail server configuration</h2>
                    <p class="help-card-copy">
                        These are the connection details you should enter in desktop and mobile email clients. If you are unsure, choose IMAP for incoming mail and the secure SMTP port for outgoing mail.
                    </p>

                    <div class="help-protocol-grid">
                        <article class="help-protocol">
                            <span class="help-protocol-label">Incoming</span>
                            <h4>IMAP</h4>
                            <dl>
                                <dt>Purpose</dt>
                                <dd>Keep messages and folders synced across devices.</dd>
                                <dt>Server</dt>
                                <dd>{{setup.imap.hostname}}</dd>
                                <dt>Port</dt>
                                <dd>{{setup.imap.port}}</dd>
                                <dt>Security</dt>
                                <dd>{{#if setup.imap.secure}}TLS / SSL{{else}}STARTTLS{{/if}}</dd>
                                <dt>Username</dt>
                                <dd>{{#if user}}{{user.address}}{{else}}yourname@{{serviceDomain}}{{/if}}</dd>
                            </dl>
                        </article>

                        <article class="help-protocol">
                            <span class="help-protocol-label">Incoming</span>
                            <h4>POP3</h4>
                            <dl>
                                <dt>Purpose</dt>
                                <dd>Download inbox messages to one device.</dd>
                                <dt>Server</dt>
                                <dd>{{setup.pop3.hostname}}</dd>
                                <dt>Port</dt>
                                <dd>{{setup.pop3.port}}</dd>
                                <dt>Security</dt>
                                <dd>{{#if setup.pop3.secure}}TLS / SSL{{else}}STARTTLS{{/if}}</dd>
                                <dt>Username</dt>
                                <dd>{{#if user}}{{user.address}}{{else}}yourname@{{serviceDomain}}{{/if}}</dd>
                            </dl>
                        </article>

                        <article class="help-protocol">
                            <span class="help-protocol-label">Outgoing</span>
                            <h4>SMTP</h4>
                            <dl>
                                <dt>Purpose</dt>
                                <dd>Send messages from your email client.</dd>
                                <dt>Server</dt>
                                <dd>{{setup.smtp.hostname}}</dd>
                                <dt>Port</dt>
                                <dd>{{setup.smtp.port}}</dd>
                                <dt>Security</dt>
                                <dd>{{#if setup.smtp.secure}}TLS / SSL{{else}}STARTTLS{{/if}}</dd>
                                <dt>Username</dt>
                                <dd>{{#if user}}{{user.address}}{{else}}yourname@{{serviceDomain}}{{/if}}</dd>
                            </dl>
                        </article>
                    </div>

                    <div class="help-note info">
                        <i class="fa-solid fa-circle-info"></i>
                        <div>
                            Your regular mailbox password works for mail apps unless two-factor authentication is enabled. {{#if use2fa}}Two-factor authentication is currently active on your account, so you should generate application-specific passwords from <a href="/account/security/asps">Security Settings</a>.{{else}}If you later enable 2FA, switch your clients over to application-specific passwords for better compatibility.{{/if}}
                        </div>
                    </div>
                </section>

                <section class="help-guide-card">
                    <h2 class="help-card-title">Recommended setup flow</h2>
                    <p class="help-card-copy">
                        If you are adding your mailbox to a new device, this is the fastest low-friction path that works reliably for most clients.
                    </p>

                    <ol class="help-guide-list">
                        <li>
                            <span class="help-step-number">1</span>
                            <div class="help-list-copy">
                                <strong>Choose IMAP unless you specifically need POP3.</strong>
                                <span>IMAP keeps folders, read state, and sent messages synchronized across desktop, mobile, and webmail.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-step-number">2</span>
                            <div class="help-list-copy">
                                <strong>Use your full email address as the username.</strong>
                                <span>Example: <span class="help-inline-code">name@{{serviceDomain}}</span>. This is the safest default for both incoming and outgoing settings.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-step-number">3</span>
                            <div class="help-list-copy">
                                <strong>Enable secure connection settings.</strong>
                                <span>Choose TLS/SSL or STARTTLS according to the server details shown above. Avoid plain-text or unsecured transport methods.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-step-number">4</span>
                            <div class="help-list-copy">
                                <strong>Require SMTP authentication.</strong>
                                <span>Outgoing mail should authenticate with the same mailbox credentials so your device is permitted to send messages.</span>
                            </div>
                        </li>
                    </ol>
                </section>

                <section class="help-troubleshoot-card">
                    <h2 class="help-card-title">Troubleshooting common issues</h2>
                    <p class="help-card-copy">
                        Most connection problems come from username formatting, wrong ports, cached passwords, or 2FA-related app password confusion.
                    </p>

                    <ul class="help-troubleshoot-list">
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-key"></i></span>
                            <div class="help-list-copy">
                                <strong>Login rejected</strong>
                                <span>Re-enter the password carefully and confirm you are using the full email address as the username. If 2FA is enabled, generate an app-specific password.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-paper-plane"></i></span>
                            <div class="help-list-copy">
                                <strong>Receiving works, but sending fails</strong>
                                <span>SMTP authentication is probably disabled or the outgoing username/password differs from the incoming credentials. Use the same mailbox identity for both.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-wifi"></i></span>
                            <div class="help-list-copy">
                                <strong>Client keeps timing out</strong>
                                <span>Check that the correct server names and secure ports are entered, and confirm your network allows outbound connections on those ports.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-folder-open"></i></span>
                            <div class="help-list-copy">
                                <strong>Folders or sent mail do not sync</strong>
                                <span>That usually means the client was configured as POP3 instead of IMAP. Recreate the account as IMAP if you want folder sync across devices.</span>
                            </div>
                        </li>
                    </ul>
                </section>
            </div>

            <div class="help-stack">
                <section class="help-security-card">
                    <h2 class="help-card-title">Security guidance</h2>
                    <p class="help-card-copy">
                        A secure mailbox setup is not only about password strength. It also depends on transport security, device hygiene, and whether you isolate mail app access properly.
                    </p>

                    <ul class="help-security-list">
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-shield-halved"></i></span>
                            <div class="help-list-copy">
                                <strong>Prefer IMAP with secure transport</strong>
                                <span>It gives you synchronized access while preserving encrypted transport where supported by the service settings above.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-mobile-screen"></i></span>
                            <div class="help-list-copy">
                                <strong>Use app-specific passwords when 2FA is active</strong>
                                <span>This lets you keep stronger account protection without breaking compatibility with desktop or mobile mail apps.</span>
                            </div>
                        </li>
                        <li>
                            <span class="help-bullet"><i class="fa-solid fa-rotate"></i></span>
                            <div class="help-list-copy">
                                <strong>Revoke old mail app credentials periodically</strong>
                                <span>If you stop using a device or app, remove its dedicated password from the security settings page.</span>
                            </div>
                        </li>
                    </ul>

                    {{#if use2fa}}
                    <div class="help-note warn" style="margin-top:22px;">
                        <i class="fa-solid fa-lock"></i>
                        <div>
                            Two-factor authentication is enabled on this account. For IMAP, POP3, and SMTP, create application-specific passwords in <a href="/account/security/asps">Account Security</a> instead of using your main login secret directly.
                        </div>
                    </div>
                    {{/if}}
                </section>

                <section class="help-support-card">
                    <h2 class="help-card-title">Need a human?</h2>
                    <p class="help-card-copy">
                        If you are still blocked after checking the configuration above, these are the best next places to go depending on the issue.
                    </p>

                    <div class="help-support-links">
                        <a href="/contact" class="help-support-link">
                            <span>Contact support</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                        <a href="/account/security" class="help-support-link">
                            <span>Review security settings</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                        {{#if user}}
                        <a href="/account/" class="help-support-link">
                            <span>Open your account dashboard</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                        {{else}}
                        <a href="/account/login" class="help-support-link">
                            <span>Sign in to your account</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                        {{/if}}
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>
