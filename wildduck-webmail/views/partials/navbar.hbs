<script>
document.addEventListener('DOMContentLoaded', function () {
    var navToggle = document.querySelector('.navbar-toggle');
    var navCollapse = document.getElementById('yoover-nav-collapse');
    var profileZone = document.querySelector('.profile-zone');
    var profileToggle = document.getElementById('profileMenuToggle');
    var mobileBreakpoint = 767;

    var syncNavExpanded = function (isOpen) {
        if (!navToggle || !navCollapse) {
            return;
        }

        navToggle.classList.toggle('collapsed', !isOpen);
        navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        navCollapse.classList.toggle('in', isOpen);
        navCollapse.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };

    var closeNavMenu = function () {
        syncNavExpanded(false);
    };

    var isMobileNav = function () {
        return window.innerWidth <= mobileBreakpoint;
    };

    if (navToggle && navCollapse) {
        syncNavExpanded(navCollapse.classList.contains('in'));

        navToggle.addEventListener('click', function (event) {
            if (!isMobileNav()) {
                return;
            }

            event.preventDefault();
            event.stopPropagation();
            syncNavExpanded(!navCollapse.classList.contains('in'));
        });

        navCollapse.querySelectorAll('a').forEach(function (link) {
            link.addEventListener('click', function () {
                if (isMobileNav()) {
                    closeNavMenu();
                }
            });
        });

        window.addEventListener('resize', function () {
            if (!isMobileNav()) {
                navCollapse.classList.remove('in');
                navToggle.classList.add('collapsed');
                navToggle.setAttribute('aria-expanded', 'false');
                navCollapse.setAttribute('aria-expanded', 'false');
            }
        });

        document.addEventListener('click', function (event) {
            if (!isMobileNav()) {
                return;
            }

            if (!navCollapse.contains(event.target) && !navToggle.contains(event.target)) {
                closeNavMenu();
            }
        });
    }

    if (!profileZone || !profileToggle) {
        return;
    }

    var closeProfileMenu = function () {
        profileZone.classList.remove('open');
        profileToggle.setAttribute('aria-expanded', 'false');
    };

    profileToggle.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        var isOpen = profileZone.classList.toggle('open');
        profileToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    document.addEventListener('click', function (event) {
        if (!profileZone.contains(event.target)) {
            closeProfileMenu();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeProfileMenu();
        }
    });
});
</script>
