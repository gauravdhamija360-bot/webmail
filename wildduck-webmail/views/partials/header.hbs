<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">

<title>{{#if seo.title}}{{seo.title}}{{else}}{{serviceName}}{{#if title}} | {{title}}{{/if}}{{/if}}</title>
<meta name="description" content="{{seo.description}}">
<meta name="author" content="Yoover Email Services">
<meta name="robots" content="{{seo.robots}}">
<meta name="application-name" content="{{serviceName}}">
<meta property="og:site_name" content="{{serviceName}}">
<meta property="og:title" content="{{seo.ogTitle}}">
<meta property="og:description" content="{{seo.ogDescription}}">
<meta property="og:type" content="{{seo.ogType}}">
<meta property="og:url" content="{{seo.canonicalUrl}}">
<meta property="og:image" content="{{seo.ogImage}}">
<meta property="og:image:alt" content="{{serviceName}} secure email by Yoover">
<meta name="twitter:card" content="{{seo.twitterCard}}">
<meta name="twitter:title" content="{{seo.twitterTitle}}">
<meta name="twitter:description" content="{{seo.twitterDescription}}">
<meta name="twitter:image" content="{{seo.twitterImage}}">
<link rel="canonical" href="{{seo.canonicalUrl}}">
{{#if googleSiteVerification}}<meta name="google-site-verification" content="{{googleSiteVerification}}">{{/if}}
{{#if seo.structuredData}}
<script type="application/ld+json">{{{seo.structuredData}}}</script>
{{/if}}

<link rel="icon" type="image/svg+xml" href="/images/yoover-logo.svg">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="shortcut icon" href="/favicon.ico">
<link rel="apple-touch-icon" href="/logo.png">
<meta name="theme-color" content="#1A73E8">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/bootstrap-3.3.7/css/lumen.css">
<link rel="stylesheet" href="/css/wildduck.css">
<link rel="stylesheet" href="/css/modern.css">

<style>
    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        color: #2c3e50;
    }
    
    /* Smooth button transitions globally */
    .btn {
        transition: all 0.2s ease-in-out;
        border-radius: 6px;
    }

    /* Custom Scrollbar for a premium feel */
    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: #1A73E8;
    }
</style>

{{#if analytics.enabled}}
<script async src="https://www.googletagmanager.com/gtag/js?id={{analytics.gaMeasurementId}}"></script>
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
        dataLayer.push(arguments);
    }

    gtag('js', new Date());
    gtag('config', '{{analytics.gaMeasurementId}}', {
        page_location: '{{seo.canonicalUrl}}',
        anonymize_ip: true,
        allow_google_signals: false
    });

    document.addEventListener('DOMContentLoaded', function () {
        document.body.addEventListener('click', function (event) {
            var trackedElement = event.target.closest('[data-analytics-event]');

            if (!trackedElement) {
                return;
            }

            gtag('event', trackedElement.getAttribute('data-analytics-event'), {
                event_category: trackedElement.getAttribute('data-analytics-category') || 'engagement',
                event_label: trackedElement.getAttribute('data-analytics-label') || trackedElement.getAttribute('href') || trackedElement.textContent.trim()
            });
        });

        document.querySelectorAll('form[data-analytics-form]').forEach(function (form) {
            form.addEventListener('submit', function () {
                gtag('event', form.getAttribute('data-analytics-form'), {
                    event_category: form.getAttribute('data-analytics-category') || 'form',
                    event_label: form.getAttribute('action') || window.location.pathname
                });
            });
        });
    });
</script>
{{/if}}
