<div class="login-shell">
    <div class="login-layout">
        <section class="login-brand-panel">
            <div class="login-brand-backdrop"></div>
            <div class="login-brand-content">
                <img src="/images/yoover-logo-white.svg" alt="Yoover" class="login-brand-logo">

                <div class="login-brand-copy">
                    <span class="login-eyebrow">Secure Account Access</span>
                    <h1>Welcome back to your Yoover mailbox.</h1>
                    <p>
                        Sign in to manage your inbox, account security, billing, and identities from one place. Clean workflow, private infrastructure, and access that feels professional from the first click.
                    </p>
                </div>

                <div class="login-brand-grid">
                    <div class="login-brand-stat">
                        <strong>Private by design</strong>
                        <span>Focused email experience without ad-driven clutter.</span>
                    </div>
                    <div class="login-brand-stat">
                        <strong>Works across devices</strong>
                        <span>Webmail, desktop clients, and mobile apps stay aligned.</span>
                    </div>
                    <div class="login-brand-stat">
                        <strong>Security controls</strong>
                        <span>2FA, app passwords, and account visibility when you need it.</span>
                    </div>
                    <div class="login-brand-stat">
                        <strong>Billing in account</strong>
                        <span>Plans, sync status, payment methods, and renewal context.</span>
                    </div>
                </div>

                <div class="login-brand-status">
                    <i class="glyphicon glyphicon-lock"></i>
                    <span>Secure session entry for {{serviceDomain}}</span>
                </div>
            </div>
        </section>

        <section class="login-form-panel">
            <div class="login-form-wrap">
                <div class="login-mobile-logo">
                    <img src="/images/yoover-logo.svg" alt="Yoover">
                </div>

                <div class="login-form-head">
                    <span class="login-form-chip">Account Login</span>
                    <h2>Sign in to your account</h2>
                    <p>Use your mailbox identity and password to continue. If two-factor authentication is enabled, your device key helper will prepare the token automatically.</p>
                </div>

                <form method="post" action="/account/login" class="login-form-card">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <input type="hidden" name="_2faToken" id="_2faToken" value="">

                    <div class="login-field {{#if errors.username}}field-error{{/if}}">
                        <label for="username">Email Address or Username</label>
                        <div class="login-input-wrap">
                            <span class="login-input-icon glyphicon glyphicon-user"></span>
                            <input type="text" name="username" id="username" value="{{values.username}}" required autofocus placeholder="name@{{serviceDomain}}">
                        </div>
                        {{#if errors.username}}<span class="err-msg">{{errors.username}}</span>{{/if}}
                    </div>

                    <div class="login-field {{#if errors.password}}field-error{{/if}}">
                        <label for="password">Password</label>
                        <div class="login-input-wrap">
                            <span class="login-input-icon glyphicon glyphicon-lock"></span>
                            <input type="password" name="password" id="password" required placeholder="Enter your password">
                        </div>
                        {{#if errors.password}}<span class="err-msg">{{errors.password}}</span>{{/if}}
                    </div>

                    <div class="login-meta-row">
                        <label class="login-checkbox">
                            <input type="checkbox" name="remember">
                            <span class="login-checkbox-box"></span>
                            Keep me signed in
                        </label>
                        <a href="/account/reset" class="login-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="login-submit">
                        <span>Access Account</span>
                        <i class="glyphicon glyphicon-menu-right"></i>
                    </button>
                </form>

                <div class="login-footnote">
                    <span>Need a new mailbox?</span>
                    <a href="/purchase">Create your Yoover account</a>
                </div>
            </div>
        </section>
    </div>
</div>

<script src="/login-key-handler.js"></script>
<script>
loginKeyHandler.setup(
    document.getElementById('username'),
    document.getElementById('_2faToken'),
    '2fa'
);
</script>

