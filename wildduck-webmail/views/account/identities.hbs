<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker">
                    <i class="glyphicon glyphicon-tags"></i>
                    Identities
                </span>
                <h1 class="account-page-title">Manage the addresses that represent you across your Yoover account.</h1>
                <p class="account-page-copy">
                    Identities let you receive mail through multiple addresses while keeping one mailbox workflow. Use them for role-based inboxes, cleaner signups, or separating public-facing aliases from your primary identity.
                </p>
                <div class="account-page-meta">
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-inbox"></i>
                        {{identities.length}} connected address entries
                    </div>
                    {{#if canCreate}}
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-plus"></i>
                        Additional identities available
                    </div>
                    {{/if}}
                </div>
            </section>

            <aside class="account-page-side">
                <h3>Identity tips</h3>
                <ul class="account-side-list">
                    <li>
                        <i class="glyphicon glyphicon-ok-circle"></i>
                        <span>Aliases can receive mail like your main address while protecting your primary identity.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-star"></i>
                        <span>Your primary address stays fixed and cannot be removed from this page.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-briefcase"></i>
                        <span>Use separate identities for clients, signups, newsletters, or team-facing communication.</span>
                    </li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card">
            <ul class="nav nav-tabs account-tabs" role="tablist">
                {{> accountmenu}}
            </ul>
        </div>

        <div class="account-content">
            <div class="account-info-banner">
                <i class="glyphicon glyphicon-info-sign"></i>
                <p>Aliases act like your main address for receiving messages. They are useful for keeping public-facing signups separate from your core mailbox identity without managing another inbox.</p>
            </div>

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Registered Addresses</h3>
                        <p>These are the identities currently attached to your account.</p>
                    </div>
                    {{#if canCreate}}
                    <div class="account-actions">
                        <a href="/account/identities/create" class="account-btn primary">
                            <i class="glyphicon glyphicon-plus"></i>
                            Add Identity
                        </a>
                    </div>
                    {{/if}}
                </div>

                <div class="account-table-wrap">
                    <table class="table account-table">
                        <thead>
                            <tr>
                                <th width="70">#</th>
                                <th>Display Name</th>
                                <th>Email Address</th>
                                <th>Created</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each identities}}
                            <tr>
                                <td>{{index}}</td>
                                <td>{{#if name}}{{name}}{{else}}<span class="text-muted">Not set</span>{{/if}}</td>
                                <td>
                                    <strong>{{address}}</strong>
                                    {{#if main}}<span class="account-mini-pill" style="margin-left: 10px;">Primary</span>{{/if}}
                                </td>
                                <td>{{created}}</td>
                                <td class="text-right">
                                    <div class="account-actions" style="justify-content: flex-end;">
                                        {{#if ../canEdit}}
                                        <a href="/account/identities/edit?id={{id}}" class="account-btn secondary">
                                            <i class="glyphicon glyphicon-pencil"></i>
                                            Edit
                                        </a>
                                        {{/if}}
                                        <button class="account-btn danger"
                                            data-address="{{address}}"
                                            {{#if main}}disabled{{else}}data-identity="{{id}}" data-toggle="modal" data-target="#deleteModal"{{/if}}>
                                            <i class="glyphicon glyphicon-trash"></i>
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                {{#unless canCreate}}
                <p class="account-empty"><i class="glyphicon glyphicon-lock"></i> Identity limit reached for your current plan tier.</p>
                {{/unless}}
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-sm centered-modal" role="document">
    <div class="modal-content account-modal">
      <div class="modal-body text-center">
        <div style="width: 72px; height: 72px; margin: 0 auto 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fff0ef; color: #c83b34; font-size: 28px;">
            <span class="glyphicon glyphicon-trash"></span>
        </div>
        <h4 style="font-weight: 800; color: #132238; margin-bottom: 10px;">Remove identity?</h4>
        <p class="text-muted">Are you sure you want to delete <strong id="delete-form-identity-val" style="color: #132238;"></strong>? This action cannot be undone.</p>
      </div>
      <div class="modal-footer" style="border-top: none; padding-top: 0;">
        <form method="post" action="/account/identities/delete" style="width: 100%;">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <input type="hidden" id="delete-form-identity" name="id" value="">
            <div class="account-actions" style="display: grid; grid-template-columns: 1fr 1fr;">
                <button type="button" class="account-btn secondary" data-dismiss="modal">Keep It</button>
                <button type="submit" class="account-btn danger">Delete</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    $('#deleteModal').on('show.bs.modal', function (event) {
        var button = $(event.relatedTarget);
        var identity = button.data('identity');
        document.getElementById('delete-form-identity').value = identity;
        document.getElementById('delete-form-identity-val').textContent = button.data('address');
    });
}, false);
</script>
