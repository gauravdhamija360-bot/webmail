<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker">
                    <i class="glyphicon glyphicon-dashboard"></i>
                    Account Overview
                </span>
                <h1 class="account-page-title">A clear view of your Yoover mailbox, usage, and account status.</h1>
                <p class="account-page-copy">
                    Track your primary identity, billing position, and key resource limits from one place. This page is designed to give you the important signals quickly without making routine account management feel crowded.
                </p>
                <div class="account-page-meta">
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-envelope"></i>
                        {{address}}
                    </div>
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-hdd"></i>
                        {{storageUsed}} used
                    </div>
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-transfer"></i>
                        {{recipientsSent}} recipients today
                    </div>
                </div>
            </section>

            <aside class="account-page-side">
                <h3>What you can do here</h3>
                <ul class="account-side-list">
                    <li>
                        <i class="glyphicon glyphicon-ok-circle"></i>
                        <span>See your current mailbox identity and whether billing is active or still syncing.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-stats"></i>
                        <span>Monitor storage, outbound recipient allowance, and forwarding usage in one dashboard.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-cog"></i>
                        <span>Jump into billing, profile, identities, and recovery tools without losing context.</span>
                    </li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card">
            <ul class="nav nav-tabs account-tabs" role="tablist">
                {{> accountmenu}}
            </ul>
        </div>

        <div class="account-content">
            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Primary Identity</h3>
                        <p>Your main Yoover address and the default address your account is operating under right now.</p>
                    </div>
                    <div class="account-actions">
                        <button type="button" id="reg-proto" class="account-btn secondary">
                            <i class="glyphicon glyphicon-envelope"></i>
                            Set Default Handler
                        </button>
                    </div>
                </div>

                <div class="account-metric-grid">
                    <div class="account-metric">
                        <span class="account-metric-label">Mailbox Address</span>
                        <strong>{{address}}</strong>
                        <small>This is the identity shown in account overview and default mailbox settings.</small>
                    </div>
                    <div class="account-metric">
                        <span class="account-metric-label">Storage Used</span>
                        <strong>{{storageUsed}}</strong>
                        <small>Current mailbox consumption against your total storage allowance.</small>
                    </div>
                    <div class="account-metric">
                        <span class="account-metric-label">Storage Limit</span>
                        <strong>{{quota}}</strong>
                        <small>Your available mailbox quota on the current account tier.</small>
                    </div>
                </div>
            </div>

            {{#if billingAccount}}
            <div class="account-dark-card">
                <div class="account-section-head">
                    <div>
                        <span class="account-status-pill">{{billingAccount.subscription.status}}</span>
                        <h3 style="margin-top: 14px;">{{billingAccount.plan.name}} billing snapshot</h3>
                        <p>{{billingAccount.emailAddress}}</p>
                    </div>
                    <div class="account-actions">
                        <a href="/account/billing" class="account-btn secondary">Manage Billing</a>
                    </div>
                </div>

                <div class="account-dark-grid">
                    <div class="account-dark-item">
                        <span>Plan Price</span>
                        <strong>{{billingAccount.plan.formattedPrice}}</strong>
                    </div>
                    <div class="account-dark-item">
                        <span>Status</span>
                        <strong>{{billingAccount.subscription.status}}</strong>
                    </div>
                    <div class="account-dark-item">
                        <span>Next Charge</span>
                        <strong>{{#if billingAccount.subscription.nextBillingAt}}{{billingAccount.subscription.nextBillingAt}}{{else}}Not scheduled{{/if}}</strong>
                    </div>
                </div>
            </div>
            {{/if}}

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Usage & Capacity</h3>
                        <p>These indicators show how much of your current account allowance is being used today.</p>
                    </div>
                </div>

                <div class="account-content" style="gap: 22px;">
                    <div>
                        <div class="account-section-head" style="margin-bottom: 12px;">
                            <div>
                                <h3 style="font-size: 1rem; margin: 0;">Cloud Storage</h3>
                                <p>{{storageUsed}} of {{quota}}</p>
                            </div>
                            <strong>{{storageOverview}}%</strong>
                        </div>
                        <div class="account-progress">
                            <div class="account-progress-bar" style="width: {{storageOverview}}%;"></div>
                        </div>
                    </div>

                    <div>
                        <div class="account-section-head" style="margin-bottom: 12px;">
                            <div>
                                <h3 style="font-size: 1rem; margin: 0;">Daily Outbound Limit</h3>
                                <p>{{recipientsSent}} of {{recipients}} recipients used</p>
                            </div>
                            <strong>{{recipientsOverview}}%</strong>
                        </div>
                        <div class="account-progress">
                            <div class="account-progress-bar success" style="width: {{recipientsOverview}}%;"></div>
                        </div>
                    </div>

                    <div>
                        <div class="account-section-head" style="margin-bottom: 12px;">
                            <div>
                                <h3 style="font-size: 1rem; margin: 0;">Automated Forwarding</h3>
                                <p>{{forwardsSent}} of {{forwards}} forwarding actions used</p>
                            </div>
                            <strong>{{forwardsOverview}}%</strong>
                        </div>
                        <div class="account-progress">
                            <div class="account-progress-bar info" style="width: {{forwardsOverview}}%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="service-name" value="{{serviceName}}" />
