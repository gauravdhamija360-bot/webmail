<div class="yoover-centered-container">
    <div class="yoover-view-header">
        <div class="header-icon-bg">
            <span class="glyphicon glyphicon-user"></span>
        </div>
        <div class="header-text">
            <h1>Account Overview</h1>
            <p class="text-muted">Manage your digital identity and resource usage.</p>
        </div>
    </div>

    <div class="yoover-tabs-wrapper">
        <ul class="nav nav-tabs yoover-nav-tabs" role="tablist">
            {{> accountmenu}}
        </ul>
    </div>

    <div class="yoover-main-card">
        <div class="tab-content">
            <div role="tabpanel" class="tab-pane active" id="overview">
                
                <div class="overview-grid">
                    <div class="overview-card primary-card">
                        <div class="card-inner">
                            <label class="yoover-label-sm">Primary Identity</label>
                            <h2 class="address-display">{{address}}</h2>
                            
                            <div class="action-spacer">
                                <button type="button" id="reg-proto" class="btn btn-yoover-outline btn-sm">
                                    <span class="glyphicon glyphicon-envelope"></span> Set as default handler
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="usage-section">
                        <h3 class="section-title">Resource Consumption</h3>
                        
                        <div class="usage-widget">
                            <div class="usage-info">
                                <span class="usage-label">Cloud Storage</span>
                                <span class="usage-stats"><strong>{{storageUsed}}</strong> / {{quota}}</span>
                            </div>
                            <div class="yoover-progress-container">
                                <div class="yoover-progress-bar" role="progressbar" style="width: {{storageOverview}}%;">
                                    <span class="progress-text">{{storageOverview}}%</span>
                                </div>
                            </div>
                        </div>

                        <div class="usage-widget">
                            <div class="usage-info">
                                <span class="usage-label">Daily Outbound Limit</span>
                                <span class="usage-stats"><strong>{{recipientsSent}}</strong> / {{recipients}}</span>
                            </div>
                            <div class="yoover-progress-container">
                                <div class="yoover-progress-bar success" role="progressbar" style="width: {{recipientsOverview}}%;">
                                    <span class="progress-text">{{recipientsOverview}}%</span>
                                </div>
                            </div>
                        </div>

                        <div class="usage-widget">
                            <div class="usage-info">
                                <span class="usage-label">Automated Forwarding</span>
                                <span class="usage-stats"><strong>{{forwardsSent}}</strong> / {{forwards}}</span>
                            </div>
                            <div class="yoover-progress-container">
                                <div class="yoover-progress-bar info" role="progressbar" style="width: {{forwardsOverview}}%;">
                                    <span class="progress-text">{{forwardsOverview}}%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<input type="hidden" id="service-name" value="{{serviceName}}" />

<style>
    /* CENTERED LAYOUT ENGINE */
    .yoover-centered-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
        animation: fadeIn 0.5s ease-out;
    }

    /* THE GLASS CARD WRAPPER */
    .yoover-main-card {
        background: #ffffff;
        border: 1px solid #e1e8ed;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }

    /* HEADER REFINEMENT */
    .yoover-view-header { display: flex; align-items: center; gap: 20px; margin-bottom: 25px; }
    .header-icon-bg { 
        width: 56px; height: 56px; background: #e8f0fe; color: #1A73E8; 
        border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; 
    }
    .header-text h1 { margin: 0; font-size: 28px; font-weight: 800; color: #202124; letter-spacing: -0.5px; }

    /* MODERN TABS */
    .yoover-tabs-wrapper { margin-bottom: 30px; border-bottom: 2px solid #f1f3f4; }
    .yoover-nav-tabs { border: none; }
    .yoover-nav-tabs > li > a { 
        border: none !important; font-weight: 700; color: #80868b; 
        padding: 12px 20px; transition: 0.3s; font-size: 15px;
    }
    .yoover-nav-tabs > li.active > a { color: #1A73E8 !important; position: relative; background: transparent !important; }
    .yoover-nav-tabs > li.active > a:after { 
        content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 3px; 
        background: #1A73E8; border-radius: 3px; 
    }

    /* GRID & CONTENT */
    .overview-grid { display: flex; flex-direction: column; gap: 40px; }
    
    .overview-card { 
        background: #f8fbff; border: 1px solid #d0e3ff; border-radius: 20px; 
        padding: 30px; position: relative; overflow: hidden;
    }
    .primary-card:before {
        content: ''; position: absolute; left: 0; top: 0; bottom: 0; 
        width: 6px; background: #1A73E8;
    }
    
    .yoover-label-sm { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: #5f6368; font-weight: 800; }
    .address-display { margin: 8px 0; font-size: 24px; color: #1A73E8; font-weight: 800; }

    .section-title { font-size: 14px; font-weight: 800; color: #202124; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 1px; }

    /* USAGE WIDGETS */
    .usage-widget { margin-bottom: 30px; }
    .usage-info { display: flex; justify-content: space-between; margin-bottom: 10px; }
    .usage-label { font-weight: 700; color: #3c4043; font-size: 14px; }
    .usage-stats { font-size: 13px; color: #5f6368; }

    /* CUSTOM PROGRESS BARS */
    .yoover-progress-container { background: #f1f3f4; height: 10px; border-radius: 20px; overflow: hidden; }
    .yoover-progress-bar { 
        height: 100%; background: #1A73E8; border-radius: 20px; 
        display: flex; align-items: center; justify-content: flex-end; transition: width 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67);
    }
    .yoover-progress-bar.success { background: #34A853; }
    .yoover-progress-bar.info { background: #12b5cb; }
    .progress-text { font-size: 9px; color: white; font-weight: 900; padding-right: 8px; }

    .btn-yoover-outline { 
        border: 2px solid #1A73E8; color: #1A73E8; background: transparent; 
        font-weight: 700; border-radius: 10px; padding: 8px 16px; transition: 0.3s; 
    }
    .btn-yoover-outline:hover { background: #1A73E8; color: white; transform: translateY(-1px); }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>