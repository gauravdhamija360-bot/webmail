<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker">
                    <i class="glyphicon glyphicon-repeat"></i>
                    Restore Messages
                </span>
                <h1 class="account-page-title">Recover recently deleted email without leaving your account workspace.</h1>
                <p class="account-page-copy">
                    Yoover can restore messages that were removed within the supported recovery window. Choose the exact time range you want to recover and submit one clean task so the mailbox can be rebuilt without duplication.
                </p>
                <div class="account-page-meta">
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-time"></i>
                        Recovery window: 25 days
                    </div>
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-tasks"></i>
                        One recovery task at a time is best
                    </div>
                </div>
            </section>

            <aside class="account-page-side">
                <h3>Before you restore</h3>
                <ul class="account-side-list">
                    <li>
                        <i class="glyphicon glyphicon-info-sign"></i>
                        <span>Very recent deletions can still be indexing, so they may not appear instantly.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-hourglass"></i>
                        <span>Larger restore ranges can take longer depending on mailbox size and server workload.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-ok-circle"></i>
                        <span>Choose one accurate range instead of starting multiple overlapping restores.</span>
                    </li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card">
            <ul class="nav nav-tabs account-tabs" role="tablist">
                {{> accountmenu}}
            </ul>
        </div>

        <div class="account-content">
            <div class="account-info-banner warning">
                <i class="glyphicon glyphicon-warning-sign"></i>
                <p><strong>Retention policy:</strong> Messages deleted within the last 25 days can be restored. Recovery work may complete in minutes or take several hours depending on the volume involved, so avoid creating duplicate tasks.</p>
            </div>

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Start A Recovery Task</h3>
                        <p>Select the exact deletion window you want us to search and inject back into your mailbox.</p>
                    </div>
                </div>

                <form method="post" action="/account/restore" id="restoreForm">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <input type="hidden" id="start" name="start" value="{{#if values.start}}{{values.start}}{{/if}}">
                    <input type="hidden" id="end" name="end" value="{{#if values.end}}{{values.end}}{{/if}}">

                    <div class="account-form-grid">
                        <div class="account-field full">
                            <label for="daterange">Select Time Range</label>
                            <div style="position: relative;">
                                <span class="glyphicon glyphicon-calendar" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #1d63d8; z-index: 1;"></span>
                                <input type="text" id="daterange" class="account-input" readonly placeholder="Select start and end time" style="padding-left: 48px; cursor: pointer;">
                            </div>
                            <p class="account-help">Only messages deleted inside this window will be restored. Use the narrowest accurate range for best results.</p>
                        </div>
                    </div>

                    <div class="account-actions" style="justify-content: center; margin-top: 8px;">
                        <button type="submit" class="account-btn primary">
                            <i class="glyphicon glyphicon-refresh"></i>
                            Start Restoring
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const startValue = (document.getElementById('start').value || '').trim();
    const endValue = (document.getElementById('end').value || '').trim();

    document.addEventListener("DOMContentLoaded", function () {
        const rangeOptions = {
            "showDropdowns": true,
            "showISOWeekNumbers": true,
            "timePicker": true,
            "timePicker24Hour": true,
            "autoApply": true,
            "autoUpdateInput": false,
            minDate: new Date(Date.now() - 25 * 24 * 3600 * 1000),
            maxDate: new Date(),
            "locale": {
                "direction": "ltr",
                "format": "DD/MM/YYYY HH:mm",
                "separator": " - ",
                "applyLabel": "Set Range",
                "cancelLabel": "Clear",
                "daysOfWeek": ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"],
                "monthNames": ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"],
                "firstDay": 1
            },
            "alwaysShowCalendars": true
        };

        if (startValue) {
            rangeOptions.startDate = moment(Number(startValue));
        }

        if (endValue) {
            rangeOptions.endDate = moment(Number(endValue));
        }

        $('#daterange').daterangepicker(rangeOptions, function (start, end) {
            document.getElementById('start').value = start.valueOf();
            document.getElementById('end').value = end.valueOf();
            document.getElementById('daterange').value = start.format('DD/MM/YYYY HH:mm') + ' – ' + end.format('DD/MM/YYYY HH:mm');
        });

        if (startValue && endValue) {
            document.getElementById('daterange').value = moment(Number(startValue)).format('DD/MM/YYYY HH:mm') + ' – ' + moment(Number(endValue)).format('DD/MM/YYYY HH:mm');
        }
    });
</script>
