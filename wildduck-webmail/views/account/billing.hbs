<div class="account-shell">
    <div class="account-wrap billing-account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker">
                    <i class="glyphicon glyphicon-credit-card"></i>
                    Billing & Subscription
                </span>
                <h1 class="account-page-title">Manage your Yoover plan, payment methods, and renewal status in one place.</h1>
                <p class="account-page-copy">
                    This billing area brings together your current subscription state, saved payment methods, transaction history, and sandbox or live sync status so you always know what the account is waiting on.
                </p>
                <div class="account-page-meta">
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-envelope"></i>
                        {{#if billingAccount}}{{billingAccount.emailAddress}}{{else}}No billing profile yet{{/if}}
                    </div>
                    {{#if billingAccount}}
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-usd"></i>
                        {{billingAccount.plan.formattedPrice}}
                    </div>
                    {{/if}}
                </div>
            </section>

            <aside class="account-page-side">
                <h3>Billing workspace</h3>
                <ul class="account-side-list">
                    <li>
                        <i class="glyphicon glyphicon-repeat"></i>
                        <span>Re-sync subscription status if sandbox or gateway records are still catching up.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-lock"></i>
                        <span>Add and manage stored cards for future renewals without leaving your account.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-list-alt"></i>
                        <span>Review historical charges and spot when a payment or renewal still needs attention.</span>
                    </li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card">
            <ul class="nav nav-tabs account-tabs" role="tablist">
                {{> accountmenu}}
            </ul>
        </div>

        {{#if billingAccount}}
        <div class="account-content">
            <div class="account-dark-card">
                <div class="account-section-head">
                    <div>
                        <span class="account-status-pill">{{billingAccount.subscription.status}}</span>
                        <h3 style="margin-top: 14px;">{{billingAccount.plan.name}} plan</h3>
                        <p>{{billingAccount.emailAddress}}</p>
                    </div>
                    <div class="account-actions">
                        <strong style="font-size: 1.2rem;">{{billingAccount.plan.formattedPrice}}</strong>
                        {{#if canSyncSubscription}}
                        <form method="post" action="/account/billing/sync" class="sync-action-form">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <button type="submit" class="account-btn secondary">Sync Billing</button>
                        </form>
                        {{/if}}
                    </div>
                </div>

                <div class="account-dark-grid">
                    <div class="account-dark-item">
                        <span>Status</span>
                        <strong>{{billingAccount.subscription.status}}</strong>
                    </div>
                    <div class="account-dark-item">
                        <span>Next Charge</span>
                        <strong>{{#if billingAccount.subscription.nextBillingAt}}{{billingAccount.subscription.nextBillingAt}}{{else}}Not scheduled yet{{/if}}</strong>
                    </div>
                    <div class="account-dark-item">
                        <span>Billing Email</span>
                        <strong>{{billingAccount.billingEmail}}</strong>
                    </div>
                </div>
            </div>

            {{#if subscriptionPending}}
            <div class="account-info-banner warning">
                <i class="glyphicon glyphicon-time"></i>
                <div>
                    <p><strong>Subscription sync is still in progress.</strong> {{#if subscriptionSetupNote}}{{subscriptionSetupNote}}{{else}}Authorize.Net sandbox can take a little time before a new recurring subscription becomes visible.{{/if}}</p>
                    {{#if canSyncSubscription}}
                    <form method="post" action="/account/billing/sync" style="margin-top: 12px;">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
                        <button type="submit" class="account-btn secondary">Try Sync Again</button>
                    </form>
                    {{/if}}
                </div>
            </div>
            {{/if}}

            <div class="account-metric-grid">
                <div class="account-metric">
                    <span class="account-metric-label">Next Charge</span>
                    <strong>{{#if billingAccount.subscription.nextBillingAt}}{{billingAccount.subscription.nextBillingAt}}{{else}}Not scheduled yet{{/if}}</strong>
                    <small>{{#if subscriptionPending}}This updates after the recurring subscription is activated.{{else}}Your next automatic renewal date.{{/if}}</small>
                </div>
                <div class="account-metric">
                    <span class="account-metric-label">Billing Email</span>
                    <strong>{{billingAccount.billingEmail}}</strong>
                    <small>Receipts and billing updates are sent to this address.</small>
                </div>
                <div class="account-metric">
                    <span class="account-metric-label">Recovery Email</span>
                    <strong>{{billingAccount.recoveryEmail}}</strong>
                    <small>Used when account recovery or manual review is needed.</small>
                </div>
            </div>

            <div class="account-two-col">
                <div class="account-card">
                    <div class="account-section-head">
                        <div>
                            <h3>Payment Methods</h3>
                            <p>Saved cards in your customer billing profile.</p>
                        </div>
                    </div>

                    {{#if billingAccount.paymentMethods.length}}
                        <div class="account-content" style="gap: 14px;">
                        {{#each billingAccount.paymentMethods}}
                            <div class="account-stat">
                                <div class="account-section-head" style="margin-bottom: 0;">
                                    <div>
                                        <h3 style="font-size: 1rem; margin-bottom: 6px;">{{#if cardType}}{{cardType}}{{else}}Card{{/if}} {{cardNumber}}</h3>
                                        <p>{{billTo.firstName}} {{billTo.lastName}} {{#if expirationDate}}• Expires {{expirationDate}}{{/if}}</p>
                                    </div>
                                    <div class="account-actions">
                                        {{#if defaultPaymentProfile}}
                                        <span class="account-mini-pill">Default</span>
                                        {{else}}
                                        <form method="post" action="/account/billing/payment-methods/{{customerPaymentProfileId}}/default">
                                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                                            <button type="submit" class="account-btn secondary">Use Next</button>
                                        </form>
                                        {{/if}}
                                        <form method="post" action="/account/billing/payment-methods/{{customerPaymentProfileId}}/delete">
                                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                                            <button type="submit" class="account-btn danger">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {{/each}}
                        </div>
                    {{else}}
                        <p class="account-empty">No payment methods saved yet.</p>
                    {{/if}}
                </div>

                <div class="account-card">
                    <div class="account-section-head">
                        <div>
                            <h3>Add Payment Method</h3>
                            <p>Add another card for future renewals and account continuity.</p>
                        </div>
                    </div>

                    {{#if addMethodErrors.general}}
                    <div class="alert alert-danger">{{addMethodErrors.general}}</div>
                    {{/if}}

                    <form id="addPaymentMethodForm" method="post" action="/account/billing/payment-methods">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
                        <input type="hidden" name="dataDescriptor" id="addDataDescriptor">
                        <input type="hidden" name="dataValue" id="addDataValue">

                        <div class="account-form-grid">
                            <div class="account-field">
                                <label>Full Name</label>
                                <input type="text" name="fullName" value="{{addMethodValues.fullName}}" required>
                                {{#if addMethodErrors.fullName}}<span class="account-error">{{addMethodErrors.fullName}}</span>{{/if}}
                            </div>
                            <div class="account-field">
                                <label>Company</label>
                                <input type="text" name="company" value="{{addMethodValues.company}}">
                            </div>
                            <div class="account-field full">
                                <label>Address Line 1</label>
                                <input type="text" name="addressLine1" value="{{addMethodValues.addressLine1}}" required>
                                {{#if addMethodErrors.addressLine1}}<span class="account-error">{{addMethodErrors.addressLine1}}</span>{{/if}}
                            </div>
                            <div class="account-field full">
                                <label>Address Line 2</label>
                                <input type="text" name="addressLine2" value="{{addMethodValues.addressLine2}}">
                            </div>
                            <div class="account-field">
                                <label>City</label>
                                <input type="text" name="city" value="{{addMethodValues.city}}" required>
                            </div>
                            <div class="account-field">
                                <label>State</label>
                                <input type="text" name="state" value="{{addMethodValues.state}}" required>
                            </div>
                            <div class="account-field">
                                <label>ZIP</label>
                                <input type="text" name="zip" value="{{addMethodValues.zip}}" required>
                            </div>
                            <div class="account-field">
                                <label>Country</label>
                                <input type="text" name="country" value="{{addMethodValues.country}}" maxlength="2" required>
                            </div>
                            <div class="account-field">
                                <label>Card Number</label>
                                <input type="text" id="billingCardNumber" autocomplete="cc-number">
                            </div>
                            <div class="account-field">
                                <label>CVV</label>
                                <input type="text" id="billingCardCode" autocomplete="cc-csc">
                            </div>
                            <div class="account-field">
                                <label>Expiry Month</label>
                                <input type="text" id="billingExpMonth" placeholder="MM" autocomplete="cc-exp-month">
                            </div>
                            <div class="account-field">
                                <label>Expiry Year</label>
                                <input type="text" id="billingExpYear" placeholder="YYYY" autocomplete="cc-exp-year">
                            </div>
                        </div>

                        <div class="account-actions" style="margin-top: 18px;">
                            <button type="button" id="addPaymentMethodButton" class="account-btn primary">Save Payment Method</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Recent Payments</h3>
                        <p>Transaction history recorded for this account.</p>
                    </div>
                </div>

                <div class="account-table-wrap">
                    <table class="table account-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Transaction</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#if payments.length}}
                                {{#each payments}}
                                <tr>
                                    <td>{{createdAt}}</td>
                                    <td>{{type}}</td>
                                    <td>${{amount}}</td>
                                    <td>{{status}}</td>
                                    <td>{{transactionId}}</td>
                                </tr>
                                {{/each}}
                            {{else}}
                                <tr>
                                    <td colspan="5" class="account-empty">No payments recorded yet.</td>
                                </tr>
                            {{/if}}
                        </tbody>
                    </table>
                </div>
            </div>

            {{#if billingAccount.subscription}}
            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Cancel Subscription</h3>
                        <p>Stop future recurring charges while keeping your billing history available for review.</p>
                    </div>
                </div>
                <form method="post" action="/account/billing/cancel">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <button type="submit" class="account-btn danger">Cancel Subscription</button>
                </form>
            </div>
            {{/if}}
        </div>
        {{else}}
        <div class="account-content">
            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>No Billing Profile Yet</h3>
                        <p>Choose a plan and create your hosted email identity to unlock billing management and subscription controls.</p>
                    </div>
                </div>
                <a href="/pricing" class="account-btn primary">View Plans</a>
            </div>
        </div>
        {{/if}}
    </div>
</div>

<script type="text/javascript" src="https://jstest.authorize.net/v1/Accept.js" charset="utf-8"></script>
<script>
    (function () {
        var addButton = document.getElementById('addPaymentMethodButton');
        var addForm = document.getElementById('addPaymentMethodForm');

        if (!addButton || !addForm) {
            return;
        }

        addButton.addEventListener('click', function () {
            addButton.disabled = true;
            addButton.textContent = 'Saving...';

            Accept.dispatchData(
                {
                    authData: {
                        clientKey: '{{authorizeClientKey}}',
                        apiLoginID: '{{authorizeApiLoginID}}'
                    },
                    cardData: {
                        cardNumber: document.getElementById('billingCardNumber').value,
                        month: document.getElementById('billingExpMonth').value,
                        year: document.getElementById('billingExpYear').value,
                        cardCode: document.getElementById('billingCardCode').value
                    }
                },
                function (response) {
                    if (response.messages.resultCode === 'Error') {
                        alert(response.messages.message.map(function (message) {
                            return message.text;
                        }).join('\n'));
                        addButton.disabled = false;
                        addButton.textContent = 'Save Payment Method';
                        return;
                    }

                    document.getElementById('addDataDescriptor').value = response.opaqueData.dataDescriptor;
                    document.getElementById('addDataValue').value = response.opaqueData.dataValue;
                    addForm.submit();
                }
            );
        });
    }());
</script>

<style>
    .billing-account-wrap {
        max-width: 1020px;
    }

    .billing-account-wrap .account-two-col {
        grid-template-columns: 1fr;
    }

    .billing-account-wrap .account-form-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (max-width: 991px) {
        .billing-account-wrap {
            max-width: 100%;
        }

        .billing-account-wrap .account-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
