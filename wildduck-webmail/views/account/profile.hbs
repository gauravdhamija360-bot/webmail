<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker">
                    <i class="glyphicon glyphicon-user"></i>
                    Profile Settings
                </span>
                <h1 class="account-page-title">Shape how your Yoover account is presented and how mail is handled.</h1>
                <p class="account-page-copy">
                    Update the display details attached to your mailbox, control spam filtering sensitivity, and route incoming mail where it needs to go. These settings affect how your account feels day to day across clients and support workflows.
                </p>
                <div class="account-page-meta">
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-envelope"></i>
                        {{values.username}}
                    </div>
                    <div class="account-meta-chip">
                        <i class="glyphicon glyphicon-user"></i>
                        {{#if values.name}}{{values.name}}{{else}}No display name set{{/if}}
                    </div>
                </div>
            </section>

            <aside class="account-page-side">
                <h3>Profile controls</h3>
                <ul class="account-side-list">
                    <li>
                        <i class="glyphicon glyphicon-font"></i>
                        <span>Set the name contacts see when messages are sent from your mailbox.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-filter"></i>
                        <span>Adjust how aggressive spam detection should be for incoming mail.</span>
                    </li>
                    <li>
                        <i class="glyphicon glyphicon-share-alt"></i>
                        <span>Forward mail to one or more addresses when your workflow requires it.</span>
                    </li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card">
            <ul class="nav nav-tabs account-tabs" role="tablist">
                {{> accountmenu}}
            </ul>
        </div>

        <form method="post" action="/account/profile" class="account-content">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>General Information</h3>
                        <p>Update the profile details tied to this mailbox identity.</p>
                    </div>
                </div>

                <div class="account-form-grid">
                    <div class="account-field">
                        <label>Username</label>
                        <div class="account-static">
                            <i class="glyphicon glyphicon-lock"></i>
                            <strong>{{values.username}}</strong>
                        </div>
                    </div>

                    <div class="account-field {{#if errors.name}}has-error{{/if}}">
                        <label for="name">Display Name</label>
                        <input type="text" name="name" id="name" value="{{values.name}}" class="account-input" placeholder="e.g. Gaurav Dhamija">
                        {{#if errors.name}}<span class="account-error">{{errors.name}}</span>{{/if}}
                    </div>

                    <div class="account-field full {{#if errors.spamLevel}}has-error{{/if}}">
                        <label for="spamLevel">Spam Detection Sensitivity</label>
                        <select name="spamLevel" id="spamLevel" class="account-input">
                            <option value="">-- Select Level --</option>
                            {{#each spamLevels}}
                            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{description}}</option>
                            {{/each}}
                        </select>
                        <p class="account-help">Choose how aggressively suspicious incoming mail should be filtered for this account.</p>
                        {{#if errors.spamLevel}}<span class="account-error">{{errors.spamLevel}}</span>{{/if}}
                    </div>
                </div>
            </div>

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Message Forwarding</h3>
                        <p>Send copies of incoming mail to other addresses when you need cross-inbox visibility.</p>
                    </div>
                </div>

                <div class="account-form-grid">
                    <div class="account-field full {{#if errors.targets}}has-error{{/if}}">
                        <label for="targets">Forward To</label>
                        <input type="text" name="targets" id="targets" value="{{values.targets}}" class="account-input" placeholder="user@example.com, another@example.com">
                        <p class="account-help">Separate multiple addresses with commas. Leave this field empty to keep delivery only in your Yoover mailbox.</p>
                        {{#if errors.targets}}<span class="account-error">{{errors.targets}}</span>{{/if}}
                    </div>
                </div>
            </div>

            <div class="account-actions" style="justify-content: center;">
                <button type="submit" class="account-btn primary">
                    <i class="glyphicon glyphicon-floppy-disk"></i>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
