<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker"><i class="glyphicon glyphicon-envelope"></i> GPG Encryption</span>
                <h1 class="account-page-title">Control how archived messages are protected with your public key.</h1>
                <p class="account-page-copy">If encryption is enabled, cleartext messages archived to this account can be protected with your GPG public key. Because the private key is not known to the service, key management and recovery stay your responsibility.</p>
            </section>
            <aside class="account-page-side">
                <h3>Encryption notes</h3>
                <ul class="account-side-list">
                    <li><i class="glyphicon glyphicon-lock"></i><span>If the private key is lost, encrypted messages may no longer be recoverable.</span></li>
                    <li><i class="glyphicon glyphicon-download-alt"></i><span>Use compatible tools such as Mailvelope or a GPG-capable mail client to view encrypted content.</span></li>
                    <li><i class="glyphicon glyphicon-refresh"></i><span>Uploading a new public key replaces the current one for future encrypted content.</span></li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> accountmenu}}</ul></div>
        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> securitymenu}}</ul></div>

        <form method="post" action="/account/security/gpg" class="account-content">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Encryption Settings</h3>
                        <p>Choose whether message encryption is active and update the public key tied to this account.</p>
                    </div>
                </div>

                <div class="account-form-grid">
                    <div class="account-field full {{#if errors.encryptMessages}}has-error{{/if}}">
                        <label>Encryption Mode</label>
                        <div class="account-actions">
                            <label><input type="radio" name="encryptMessages" id="encryptMessagesNo" value="false" {{#unless values.encryptMessages}}checked{{/unless}}> Disable encryption</label>
                            <label><input type="radio" name="encryptMessages" id="encryptMessagesYes" value="true" {{#if values.encryptMessages}}checked{{/if}}> Enable encryption</label>
                        </div>
                        {{#if errors.encryptMessages}}<span class="account-error">{{errors.encryptMessages}}</span>{{/if}}
                    </div>

                    {{#if fingerprint}}
                    <div class="account-field full">
                        <label>Current Key</label>
                        <div class="account-static" style="display:block;">
                            <div style="display:flex; justify-content:space-between; gap:16px; align-items:flex-start;">
                                <div>
                                    <code class="response">{{fingerprint}}</code>
                                    {{#if keyAddress}} <em>({{keyAddress}})</em>{{/if}}
                                </div>
                                <label style="margin:0;"><input type="checkbox" name="removeKey" value="yes"> Remove current key</label>
                            </div>
                        </div>
                    </div>
                    {{/if}}

                    <div class="account-field full {{#if errors.pubKey}}has-error{{/if}}">
                        <label for="pubKey">GPG Public Key{{#if fingerprint}} (replaces current key){{/if}}</label>
                        <textarea class="account-input" style="font-family: monospace;" rows="8" id="pubKey" name="pubKey" placeholder="-----BEGIN PGP PUBLIC KEY BLOCK-----">{{pubKey}}</textarea>
                        {{#if errors.pubKey}}<span class="account-error">{{errors.pubKey}}</span>{{/if}}
                        <p class="account-help">Leave this empty if you do not want to replace the current key.</p>
                    </div>
                </div>

                <div class="account-actions" style="margin-top: 22px;">
                    <button type="submit" class="account-btn primary">Update Encryption Settings</button>
                </div>
            </div>
        </form>
    </div>
</div>
