<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker"><i class="glyphicon glyphicon-phone"></i> Two-Factor Authentication</span>
                <h1 class="account-page-title">Add a second checkpoint before anyone gets into your account.</h1>
                <p class="account-page-copy">Two-factor authentication requires a time-based code from an authenticator app, and optionally a hardware security key, in addition to your password during sign in.</p>
            </section>
            <aside class="account-page-side">
                <h3>Good to know</h3>
                <ul class="account-side-list">
                    <li><i class="glyphicon glyphicon-ok-circle"></i><span>Authenticator apps such as Google Authenticator work with TOTP-based Yoover login codes.</span></li>
                    <li><i class="glyphicon glyphicon-console"></i><span>External IMAP, POP3, and SMTP apps should use app passwords when 2FA is enabled.</span></li>
                    <li><i class="glyphicon glyphicon-flash"></i><span>Hardware security keys add another strong factor when U2F support is available.</span></li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> accountmenu}}</ul></div>
        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> securitymenu}}</ul></div>

        <div class="account-content">
            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Authenticator App</h3>
                        <p>Require a rotating verification code during account login.</p>
                    </div>
                    <span class="account-mini-pill">{{#if enabledTotp}}Enabled{{else}}Disabled{{/if}}</span>
                </div>

                <div class="account-info-banner">
                    <i class="glyphicon glyphicon-info-sign"></i>
                    <p>If two-factor authentication is enabled, a code from your authenticator app is required at login. TOTP-compatible apps like Google Authenticator can be used to generate these codes.</p>
                </div>

                <div class="account-actions" style="margin-top: 18px;">
                    <a href='https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&pcampaignid=MKT-Other-global-all-co-prtnr-py-PartBadge-Mar2515-1' target="_blank" class="account-btn secondary">Google Play</a>
                    <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8" target="_blank" class="account-btn secondary">App Store</a>
                </div>

                <div class="account-metric-grid" style="margin-top: 22px;">
                    <div class="account-metric">
                        <span class="account-metric-label">Two-Factor Status</span>
                        <strong>{{#if enabled2fa}}Enabled{{else}}Disabled{{/if}}</strong>
                        <small>Main 2FA status for your account login flow.</small>
                    </div>
                    <div class="account-metric">
                        <span class="account-metric-label">Authenticator App</span>
                        <strong>{{#if enabledTotp}}Configured{{else}}Not configured{{/if}}</strong>
                        <small>App-based code verification for normal sign-in.</small>
                    </div>
                    <div class="account-metric">
                        <span class="account-metric-label">Client Access</span>
                        <strong>Use app passwords</strong>
                        <small>External clients should use application-specific passwords after enabling 2FA.</small>
                    </div>
                </div>

                <div class="account-actions" style="margin-top: 22px;">
                    {{#if enabled2fa}}
                        <button type="button" class="account-btn danger" data-toggle="modal" data-target="#deleteModal">Disable Two-Factor</button>
                    {{else}}
                        <form method="post" id="enable-2fa" action="/account/security/2fa/enable-totp">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <button type="submit" class="account-btn primary">Enable Two-Factor</button>
                        </form>
                    {{/if}}
                </div>
            </div>

            {{#if enabled2fa}}
            <div class="account-card">
                <div class="account-section-head">
                    <div>
                        <h3>Security Key</h3>
                        <p>Add a hardware-backed second factor for stronger account sign-in.</p>
                    </div>
                    <span class="account-mini-pill">{{#if enabledU2f}}Enabled{{else}}Disabled{{/if}}</span>
                </div>

                <p class="account-card-copy">If your browser and device support it, you can protect this account with a U2F security key in addition to the authenticator app flow.</p>

                <div class="account-actions" style="margin-top: 18px;">
                    {{#if enabledU2f}}
                        <button type="button" class="account-btn danger" data-toggle="modal" data-target="#revokeModal">Disable Security Key</button>
                    {{else}}
                        <form method="post" id="enable-u2f" action="/account/security/2fa/enable-u2f">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <button type="submit" class="account-btn primary">Enable Security Key</button>
                        </form>
                    {{/if}}
                </div>
            </div>
            {{/if}}
        </div>
    </div>
</div>

<div class="modal" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel">
  <div class="modal-dialog" role="document">
    <div class="modal-content account-modal">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="deleteModalLabel">Disable 2FA</h4>
      </div>
      <div class="modal-body">Are you sure you want to disable two-factor authentication?</div>
      <div class="modal-footer">
        <form method="post" action="/account/security/2fa/disable-totp">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="button" class="account-btn secondary" data-dismiss="modal">Keep Enabled</button>
            <button type="submit" class="account-btn danger">Disable</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal" id="revokeModal" tabindex="-1" role="dialog" aria-labelledby="revokeModalLabel">
  <div class="modal-dialog" role="document">
    <div class="modal-content account-modal">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="revokeModalLabel">Revoke Security Key</h4>
      </div>
      <div class="modal-body">Are you sure you want to revoke your U2F security key from this account?</div>
      <div class="modal-footer">
        <form method="post" action="/account/security/2fa/disable-u2f">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="button" class="account-btn secondary" data-dismiss="modal">Keep Enabled</button>
            <button type="submit" class="account-btn danger">Revoke</button>
        </form>
      </div>
    </div>
  </div>
</div>
