<div class="account-shell">
    <div class="account-wrap">
        <div class="account-page-head">
            <section class="account-page-hero">
                <span class="account-page-kicker"><i class="glyphicon glyphicon-lock"></i> Account Password</span>
                <h1 class="account-page-title">Refresh your password when access needs to be tightened.</h1>
                <p class="account-page-copy">Change the main password for your Yoover account here. A strong, unique password is one of the simplest ways to reduce account exposure across devices and browsers.</p>
            </section>
            <aside class="account-page-side">
                <h3>Password guidance</h3>
                <ul class="account-side-list">
                    <li><i class="glyphicon glyphicon-ok-circle"></i><span>Use a password that is unique to Yoover and not reused from other services.</span></li>
                    <li><i class="glyphicon glyphicon-warning-sign"></i><span>Update it promptly if a device, browser, or saved credential may have been compromised.</span></li>
                    <li><i class="glyphicon glyphicon-phone"></i><span>If 2FA is enabled, keep your authenticator method available before changing account access.</span></li>
                </ul>
            </aside>
        </div>

        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> accountmenu}}</ul></div>
        <div class="account-tabs-card"><ul class="nav nav-tabs account-tabs" role="tablist">{{> securitymenu}}</ul></div>

        <div class="account-content">
            <form method="post" action="/account/security/password" class="account-card">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">

                <div class="account-section-head">
                    <div>
                        <h3>Change Password</h3>
                        <p>Enter your current password, then choose the new one you want to use going forward.</p>
                    </div>
                </div>

                <div class="account-form-grid">
                    <div class="account-field full {{#if errors.existingPassword}}has-error{{/if}}">
                        <label for="existingPassword">Current Password</label>
                        <input type="password" name="existingPassword" id="existingPassword" class="account-input" autocomplete="off" placeholder="Enter current password">
                        {{#if errors.existingPassword}}<span class="account-error">{{errors.existingPassword}}</span>{{/if}}
                    </div>
                    <div class="account-field {{#if errors.password}}has-error{{/if}}">
                        <label for="password">New Password</label>
                        <input type="password" name="password" id="password" class="account-input" autocomplete="off" placeholder="Enter new password">
                        {{#if errors.password}}<span class="account-error">{{errors.password}}</span>{{/if}}
                    </div>
                    <div class="account-field {{#if errors.password}}has-error{{/if}}">
                        <label for="password2">Repeat Password</label>
                        <input type="password" name="password2" id="password2" class="account-input" autocomplete="off" placeholder="Repeat new password">
                    </div>
                </div>

                <div class="account-actions" style="margin-top: 22px;">
                    <button type="submit" class="account-btn primary">Change Password</button>
                </div>
            </form>
        </div>
    </div>
</div>
