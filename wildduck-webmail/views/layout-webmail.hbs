<!DOCTYPE html>
<html lang="en">

<head>
    {{>header}}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="/css/webmail-redesign.css" rel="stylesheet">
</head>

<body class="{{#if user}}is-logged-in{{/if}} yoover-body">

    {{>navbar}}

    <div class="flash-messages-container">
        {{flash_messages}}
    </div>

    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <div class="yoover-dashboard-wrapper">
        <div class="webmail-mobile-bar">
            <button type="button" class="sidebar-toggle" id="sidebar-toggle" aria-label="Open folders">
                <span class="glyphicon glyphicon-menu-hamburger"></span>
            </button>
            <div class="webmail-mobile-title">
                <strong>Yoover Mail</strong>
                <span>Inbox, folders, and composer</span>
            </div>
            <a href="/webmail/send" class="btn btn-yoover-compose">
                <span class="glyphicon glyphicon-edit"></span>
                <span>Compose</span>
            </a>
        </div>
        
        <aside class="yoover-sidebar" id="webmail-sidebar">
            <div class="sidebar-inner">
                <div class="sidebar-logo-box">
                    <a href="/webmail">
                        <img src="/images/yoover-logo.svg" alt="Yoover Logo" class="main-logo">
                    </a>
                    <button type="button" class="sidebar-close hidden-md hidden-lg" id="sidebar-close" aria-label="Close folders">
                        <span class="glyphicon glyphicon-remove"></span>
                    </button>
                </div>

                <div class="compose-wrapper">
                    <a href="/webmail/send" class="btn btn-yoover-compose">
                        <span class="glyphicon glyphicon-edit"></span> 
                        <span>Compose</span>
                    </a>
                </div>

                <nav class="sidebar-nav-container">
                    <div class="sidebar-scroll">
                        <p class="sidebar-section-label">Mailboxes</p>
                        <ul class="yoover-nav-list">
                            {{#each mailboxes}}
                            <li id="mailbox-list-{{id}}" class="nav-item {{#if selected}}active-folder{{/if}}">
                                <a href="/webmail/{{id}}" class="nav-link">
                                    <span class="nav-icon">
                                        {{#if icon}}
                                        <span class="glyphicon glyphicon-{{icon}}"></span>
                                        {{else}}
                                        <span class="glyphicon glyphicon-folder-close"></span>
                                        {{/if}}
                                    </span>
                                    
                                    <span class="nav-text">{{{prefix}}} {{formatted}}</span>
                                    
                                    <span class="badge badge-yoover unseen-counter-{{id}}" 
                                          {{#if unseen}}style="display: inline-flex;"{{else}}style="display: none;"{{/if}}>
                                        {{unseen}}
                                    </span>
                                </a>
                            </li>
                            {{/each}}
                        </ul>
                    </div>

                    <div class="sidebar-divider"></div>

                    <ul class="yoover-nav-list">
                        <li class="nav-item">
                            <a href="/webmail/create" class="nav-link create-folder-link">
                                <span class="glyphicon glyphicon-plus"></span>
                                <span>Create folder</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <main class="yoover-main-content">
            {{#if generalNotification}}
            <div class="yoover-system-alert">
                <div class="alert-inner">
                    <span class="glyphicon glyphicon-bullhorn"></span>
                    <div class="alert-content">{{{generalNotification}}}</div>
                </div>
            </div>
            {{/if}}

            <div class="view-render-area">
                {{{body}}}
            </div>
        </main>
    </div>

    <footer class="yoover-footer">
        <div class="container-fluid">
            <p>&copy; 2026 <a href="/">{{serviceName}}</a> &bull; <a href="mailto:info@{{serviceDomain}}">Support</a></p>
        </div>
    </footer>

    {{> scripts}}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var sidebar = document.getElementById('webmail-sidebar');
            var toggle = document.getElementById('sidebar-toggle');
            var close = document.getElementById('sidebar-close');
            var backdrop = document.getElementById('sidebar-backdrop');

            if (!sidebar || !toggle || !backdrop) {
                return;
            }

            var closeSidebar = function () {
                sidebar.classList.remove('is-open');
                backdrop.classList.remove('is-open');
                document.body.classList.remove('webmail-sidebar-open');
            };

            var openSidebar = function () {
                sidebar.classList.add('is-open');
                backdrop.classList.add('is-open');
                document.body.classList.add('webmail-sidebar-open');
            };

            toggle.addEventListener('click', function () {
                if (sidebar.classList.contains('is-open')) {
                    closeSidebar();
                    return;
                }
                openSidebar();
            });

            if (close) {
                close.addEventListener('click', closeSidebar);
            }

            backdrop.addEventListener('click', closeSidebar);

            window.addEventListener('resize', function () {
                if (window.innerWidth > 991) {
                    closeSidebar();
                }
            });
        });
    </script>

</body>

</html>
