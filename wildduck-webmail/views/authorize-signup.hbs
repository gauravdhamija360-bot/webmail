<div class="checkout-shell">
    <div class="checkout-aside">
        <div class="aside-chip">Create Your Yoover Account</div>
        <div class="sidebar-identity">
            <span class="sidebar-label">Selected address</span>
            <h1><span id="sidebarUsername">{{requestedUsername}}@{{serviceDomain}}</span></h1>
        </div>
        <p>Review your chosen identity, select a plan, and finish the setup in a guided payment flow.</p>

        <div class="step-list">
            <div class="step-item active" data-nav-step="1"><span>1</span> Identity & plan</div>
            <div class="step-item" data-nav-step="2"><span>2</span> Account details</div>
            <div class="step-item" data-nav-step="3"><span>3</span> Billing & payment</div>
        </div>

        <div class="plan-preview">
            {{#each plans}}
            <button type="button" class="plan-preview-card {{#if selected}}selected{{/if}}" data-plan-preview="{{code}}">
                <strong>{{name}}</strong>
                <span>{{price}} / {{billingLabel}}</span>
                <p>{{summary}}</p>
            </button>
            {{/each}}
        </div>
    </div>

    <div class="checkout-main">
        <form id="paymentForm" method="POST" action="/execute-authorize-payment" class="wizard-card">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <input type="hidden" name="requestedUsername" value="{{values.requestedUsername}}" id="requestedUsernameHidden">
            <input type="hidden" name="dataValue" id="dataValue">
            <input type="hidden" name="dataDescriptor" id="dataDescriptor">

            {{#if errors.general}}
            <div class="checkout-alert checkout-alert-danger">{{errors.general}}</div>
            {{/if}}

            <div class="wizard-step is-active" data-step="1">
                <div class="step-head">
                    <label class="eyebrow">Step 1</label>
                    <h2>Identity & plan</h2>
                    <p>Confirm the address you want and choose how you want it billed.</p>
                </div>

                <div class="identity-review">
                    <span class="identity-label">Selected address</span>
                    <strong id="selectedAddressLabel">{{values.requestedUsername}}@{{serviceDomain}}</strong>
                    {{#if errors.requestedUsername}}<span class="err-msg">{{errors.requestedUsername}}</span>{{/if}}
                </div>

                <div class="username-edit-card">
                    <div class="form-group" style="margin-bottom: 12px;">
                        <label for="requestedUsernameInput">Edit username</label>
                        <div class="username-inline">
                            <input type="text" class="form-control" id="requestedUsernameInput" value="{{values.requestedUsername}}" autocomplete="off" spellcheck="false">
                            <span class="username-domain">@{{serviceDomain}}</span>
                            <button type="button" class="btn btn-default" id="recheckUsernameBtn">Check</button>
                        </div>
                    </div>
                    <div id="usernameCheckResult" class="username-check-result"></div>
                </div>

                <div class="plan-grid">
                    {{#each plans}}
                    <label class="plan-card {{#if selected}}selected{{/if}}">
                        <input type="radio" name="selectedPlan" value="{{code}}" {{#if selected}}checked{{/if}}>
                        <span class="plan-name">{{name}}</span>
                        <span class="plan-price">{{price}} / {{billingLabel}}</span>
                        <span class="plan-copy">{{summary}}</span>
                        {{#if benefits.length}}
                            <span class="plan-copy">{{benefits.[0]}}</span>
                        {{/if}}
                    </label>
                    {{/each}}
                </div>
                {{#if errors.selectedPlan}}<span class="err-msg">{{errors.selectedPlan}}</span>{{/if}}
            </div>

            <div class="wizard-step" data-step="2">
                <div class="step-head">
                    <label class="eyebrow">Step 2</label>
                    <h2>Mailbox account details</h2>
                    <p>These details will be used to create the WildDuck mailbox and recovery profile.</p>
                </div>

                <div class="row">
                    <div class="col-sm-12 form-group">
                        <label>Full Name</label>
                        <input type="text" class="form-control {{#if errors.fullName}}field-error{{/if}}" name="fullName" value="{{values.fullName}}" minlength="2" maxlength="120" required>
                        {{#if errors.fullName}}<span class="err-msg">{{errors.fullName}}</span>{{/if}}
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-6 form-group">
                        <label>Recovery Email</label>
                        <input type="email" class="form-control {{#if errors.recoveryEmail}}field-error{{/if}}" name="recoveryEmail" value="{{values.recoveryEmail}}" maxlength="190" required>
                        {{#if errors.recoveryEmail}}<span class="err-msg">{{errors.recoveryEmail}}</span>{{/if}}
                    </div>
                    <div class="col-sm-6 form-group">
                        <label>Billing Email</label>
                        <input type="email" class="form-control {{#if errors.billingEmail}}field-error{{/if}}" name="billingEmail" value="{{values.billingEmail}}" maxlength="190" required>
                        {{#if errors.billingEmail}}<span class="err-msg">{{errors.billingEmail}}</span>{{/if}}
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-6 form-group">
                        <label>Password</label>
                        <input type="password" class="form-control {{#if errors.password}}field-error{{/if}}" name="password" minlength="8" maxlength="256" required>
                        {{#if errors.password}}<span class="err-msg">{{errors.password}}</span>{{/if}}
                    </div>
                    <div class="col-sm-6 form-group">
                        <label>Confirm Password</label>
                        <input type="password" class="form-control {{#if errors.password2}}field-error{{/if}}" name="password2" minlength="8" maxlength="256" required>
                        {{#if errors.password2}}<span class="err-msg">{{errors.password2}}</span>{{/if}}
                    </div>
                </div>
            </div>

            <div class="wizard-step" data-step="3">
                <div class="step-head">
                    <label class="eyebrow">Step 3</label>
                    <h2>Billing & payment</h2>
                    <p>Your payment details are secured before they ever reach this app.</p>
                </div>

                <div class="row">
                    <div class="col-sm-12 form-group">
                        <label>Company</label>
                        <input type="text" class="form-control" name="company" value="{{values.company}}" maxlength="120">
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-8 form-group">
                        <label>Address Line 1</label>
                        <input type="text" class="form-control {{#if errors.addressLine1}}field-error{{/if}}" name="addressLine1" value="{{values.addressLine1}}" minlength="3" maxlength="120" required>
                        {{#if errors.addressLine1}}<span class="err-msg">{{errors.addressLine1}}</span>{{/if}}
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>Address Line 2</label>
                        <input type="text" class="form-control" name="addressLine2" value="{{values.addressLine2}}" maxlength="120">
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>City</label>
                        <input type="text" class="form-control" name="city" value="{{values.city}}" minlength="2" maxlength="80" required>
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>State</label>
                        <input type="text" class="form-control" name="state" value="{{values.state}}" minlength="2" maxlength="80" required>
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>ZIP</label>
                        <input type="text" class="form-control" name="zip" value="{{values.zip}}" minlength="3" maxlength="20" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>Country</label>
                        <input type="text" class="form-control {{#if errors.country}}field-error{{/if}}" name="country" value="{{values.country}}" maxlength="2" minlength="2" pattern="[A-Za-z]{2}" required>
                        {{#if errors.country}}<span class="err-msg">{{errors.country}}</span>{{/if}}
                    </div>
                    <div class="col-sm-8 form-group">
                        <label>Card Number</label>
                        <input type="text" id="cardNumber" class="form-control" placeholder="4007000000027" autocomplete="cc-number" inputmode="numeric">
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-4 form-group">
                        <label>Expiry Month</label>
                        <input type="text" id="expMonth" class="form-control" placeholder="MM" autocomplete="cc-exp-month" inputmode="numeric">
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>Expiry Year</label>
                        <input type="text" id="expYear" class="form-control" placeholder="YYYY" autocomplete="cc-exp-year" inputmode="numeric">
                    </div>
                    <div class="col-sm-4 form-group">
                        <label>CVV</label>
                        <input type="text" id="cardCode" class="form-control" placeholder="123" autocomplete="cc-csc" inputmode="numeric">
                    </div>
                </div>

                <div id="paymentFieldError" class="checkout-alert checkout-alert-danger hidden"></div>
            </div>

            <div class="wizard-footer">
                <button type="button" class="btn btn-default" id="prevStep" disabled>Back</button>
                <button type="button" class="btn btn-primary" id="nextStep">Continue</button>
                <button type="button" class="btn btn-primary hidden" id="payButton">Start Secure Payment</button>
            </div>
        </form>
    </div>
</div>

<script type="text/javascript" src="https://jstest.authorize.net/v1/Accept.js" charset="utf-8"></script>
<script type="text/javascript">
    (function () {
        var currentStep = 1;
        var totalSteps = 3;
        var form = document.getElementById('paymentForm');
        var nextButton = document.getElementById('nextStep');
        var prevButton = document.getElementById('prevStep');
        var payButton = document.getElementById('payButton');
        var stepEls = document.querySelectorAll('.wizard-step');
        var stepNavEls = document.querySelectorAll('[data-nav-step]');
        var planRadios = document.querySelectorAll('.plan-card input[type="radio"]');
        var planCards = document.querySelectorAll('.plan-card');
        var planPreviewCards = document.querySelectorAll('[data-plan-preview]');
        var usernameInput = document.getElementById('requestedUsernameInput');
        var usernameHiddenInput = document.getElementById('requestedUsernameHidden');
        var selectedAddressLabel = document.getElementById('selectedAddressLabel');
        var sidebarUsername = document.getElementById('sidebarUsername');
        var recheckUsernameBtn = document.getElementById('recheckUsernameBtn');
        var usernameCheckResult = document.getElementById('usernameCheckResult');
        var paymentFieldError = document.getElementById('paymentFieldError');
        var usernamePattern = /^[a-z0-9][a-z0-9.-]*$/i;
        var serverErrors = {
            requestedUsername: '{{#if errors.requestedUsername}}{{errors.requestedUsername}}{{/if}}',
            selectedPlan: '{{#if errors.selectedPlan}}{{errors.selectedPlan}}{{/if}}',
            fullName: '{{#if errors.fullName}}{{errors.fullName}}{{/if}}',
            recoveryEmail: '{{#if errors.recoveryEmail}}{{errors.recoveryEmail}}{{/if}}',
            billingEmail: '{{#if errors.billingEmail}}{{errors.billingEmail}}{{/if}}',
            password: '{{#if errors.password}}{{errors.password}}{{/if}}',
            password2: '{{#if errors.password2}}{{errors.password2}}{{/if}}',
            addressLine1: '{{#if errors.addressLine1}}{{errors.addressLine1}}{{/if}}',
            country: '{{#if errors.country}}{{errors.country}}{{/if}}'
        };
        var usernameStatus = {
            value: usernameInput.value.trim().toLowerCase(),
            available: false
        };

        function getInitialStepFromErrors() {
            if (serverErrors.password || serverErrors.password2 || serverErrors.fullName || serverErrors.recoveryEmail || serverErrors.billingEmail) {
                return 2;
            }

            if (serverErrors.addressLine1 || serverErrors.country) {
                return 3;
            }

            return 1;
        }

        function normalizeUsername(value) {
            return value.replace(/[^a-z0-9.-]/gi, '').toLowerCase();
        }

        function updateUsernameViews(username) {
            var address = username ? username + '@{{serviceDomain}}' : '@{{serviceDomain}}';
            usernameHiddenInput.value = username;
            selectedAddressLabel.textContent = address;
            sidebarUsername.textContent = address;
        }

        function setUsernameMessage(message, type) {
            usernameCheckResult.className = 'username-check-result ' + (type || '');
            usernameCheckResult.textContent = message || '';
        }

        function setPaymentFieldError(message) {
            if (!paymentFieldError) {
                return;
            }

            paymentFieldError.textContent = message || '';
            paymentFieldError.classList.toggle('hidden', !message);
        }

        function sanitizeNumericInput(input, maxLength) {
            if (!input) {
                return '';
            }

            var digits = String(input.value || '').replace(/\D/g, '');
            if (maxLength) {
                digits = digits.slice(0, maxLength);
            }
            input.value = digits;
            return digits;
        }

        function validateStepTwo() {
            var fullNameInput = form.querySelector('input[name="fullName"]');
            var recoveryEmailInput = form.querySelector('input[name="recoveryEmail"]');
            var billingEmailInput = form.querySelector('input[name="billingEmail"]');
            var passwordInput = form.querySelector('input[name="password"]');
            var password2Input = form.querySelector('input[name="password2"]');

            if (fullNameInput && fullNameInput.value.trim().length < 2) {
                fullNameInput.setCustomValidity('Enter your full name.');
                fullNameInput.reportValidity();
                return false;
            }
            fullNameInput.setCustomValidity('');

            if (recoveryEmailInput && billingEmailInput) {
                if (recoveryEmailInput.value.trim().toLowerCase() === billingEmailInput.value.trim().toLowerCase()) {
                    billingEmailInput.setCustomValidity('Billing email must be different from recovery email.');
                    billingEmailInput.reportValidity();
                    return false;
                }
                billingEmailInput.setCustomValidity('');
            }

            if (passwordInput && passwordInput.value.length < 8) {
                passwordInput.setCustomValidity('Password must be at least 8 characters.');
                passwordInput.reportValidity();
                return false;
            }
            passwordInput.setCustomValidity('');

            if (password2Input && passwordInput && password2Input.value !== passwordInput.value) {
                password2Input.setCustomValidity('Confirm password must match your password.');
                password2Input.reportValidity();
                return false;
            }
            if (password2Input) {
                password2Input.setCustomValidity('');
            }

            return true;
        }

        function validateStepThree() {
            var countryInput = form.querySelector('input[name="country"]');
            var cardNumber = sanitizeNumericInput(document.getElementById('cardNumber'), 19);
            var expMonth = sanitizeNumericInput(document.getElementById('expMonth'), 2);
            var expYear = sanitizeNumericInput(document.getElementById('expYear'), 4);
            var cardCode = sanitizeNumericInput(document.getElementById('cardCode'), 4);
            var month = Number(expMonth);
            var year = Number(expYear);
            var now = new Date();

            setPaymentFieldError('');

            if (countryInput) {
                countryInput.value = String(countryInput.value || '').replace(/[^a-z]/gi, '').toUpperCase().slice(0, 2);
            }

            if (!cardNumber || cardNumber.length < 13) {
                setPaymentFieldError('Enter a valid card number.');
                document.getElementById('cardNumber').focus();
                return false;
            }

            if (!expMonth || month < 1 || month > 12) {
                setPaymentFieldError('Enter a valid expiry month.');
                document.getElementById('expMonth').focus();
                return false;
            }

            if (!expYear || expYear.length !== 4 || year < now.getFullYear()) {
                setPaymentFieldError('Enter a valid expiry year.');
                document.getElementById('expYear').focus();
                return false;
            }

            if (year === now.getFullYear() && month < now.getMonth() + 1) {
                setPaymentFieldError('Card expiry date must be in the future.');
                document.getElementById('expMonth').focus();
                return false;
            }

            if (!cardCode || cardCode.length < 3) {
                setPaymentFieldError('Enter a valid security code.');
                document.getElementById('cardCode').focus();
                return false;
            }

            return true;
        }

        async function checkUsernameAvailability() {
            var username = normalizeUsername(usernameInput.value.trim());
            usernameInput.value = username;
            updateUsernameViews(username);

            if (!username || username.length < 3) {
                usernameStatus = { value: username, available: false };
                setUsernameMessage('Username must be at least 3 characters.', 'error');
                return false;
            }

            if (!usernamePattern.test(username)) {
                usernameStatus = { value: username, available: false };
                setUsernameMessage('Use only letters, numbers, dots, and hyphens.', 'error');
                return false;
            }

            recheckUsernameBtn.disabled = true;
            recheckUsernameBtn.textContent = 'Checking...';
            setUsernameMessage('Checking availability...', 'pending');

            try {
                var response = await fetch('/check-username?username=' + encodeURIComponent(username));
                var data = await response.json();

                if (!response.ok) {
                    usernameStatus = { value: username, available: false };
                    setUsernameMessage(data.error || 'Unable to check username right now.', 'error');
                    return false;
                }

                if (!data.available) {
                    usernameStatus = { value: username, available: false };
                    setUsernameMessage('That username is already taken.', 'error');
                    return false;
                }

                usernameStatus = { value: username, available: true };
                setUsernameMessage(username + '@{{serviceDomain}} is available.', 'success');
                return true;
            } catch (err) {
                usernameStatus = { value: username, available: false };
                setUsernameMessage('Connection error while checking username.', 'error');
                return false;
            } finally {
                recheckUsernameBtn.disabled = false;
                recheckUsernameBtn.textContent = 'Check';
            }
        }

        function showStep(step) {
            currentStep = step;
            Array.prototype.forEach.call(stepEls, function (stepEl) {
                stepEl.classList.toggle('is-active', Number(stepEl.getAttribute('data-step')) === currentStep);
            });
            Array.prototype.forEach.call(stepNavEls, function (stepNavEl) {
                var navStep = Number(stepNavEl.getAttribute('data-nav-step'));
                stepNavEl.classList.toggle('active', navStep === currentStep);
                stepNavEl.classList.toggle('completed', navStep < currentStep);
            });

            prevButton.disabled = currentStep === 1;
            nextButton.classList.toggle('hidden', currentStep === totalSteps);
            payButton.classList.toggle('hidden', currentStep !== totalSteps);
        }

        function syncPlanSelection(selectedPlan) {
            Array.prototype.forEach.call(planCards, function (planCard) {
                var radio = planCard.querySelector('input[type="radio"]');
                planCard.classList.toggle('selected', !!radio && radio.value === selectedPlan);
            });

            Array.prototype.forEach.call(planPreviewCards, function (previewCard) {
                previewCard.classList.toggle('selected', previewCard.getAttribute('data-plan-preview') === selectedPlan);
            });
        }

        async function validateCurrentStep() {
            var activeStep = document.querySelector('.wizard-step.is-active');
            var inputs = activeStep.querySelectorAll('input[name]');

            for (var i = 0; i < inputs.length; i++) {
                if (!inputs[i].checkValidity()) {
                    inputs[i].reportValidity();
                    return false;
                }
            }

            if (currentStep === 1) {
                var normalizedUsername = normalizeUsername(usernameInput.value.trim());

                if (!normalizedUsername) {
                    usernameInput.reportValidity();
                    return false;
                }

                if (!(usernameStatus.available && usernameStatus.value === normalizedUsername)) {
                    return checkUsernameAvailability();
                }
            }

            if (currentStep === 2) {
                return validateStepTwo();
            }

            if (currentStep === 3) {
                return validateStepThree();
            }

            return true;
        }

        nextButton.addEventListener('click', async function () {
            if (!(await validateCurrentStep())) {
                return;
            }

            showStep(Math.min(totalSteps, currentStep + 1));
        });

        prevButton.addEventListener('click', function () {
            showStep(Math.max(1, currentStep - 1));
        });

        payButton.addEventListener('click', async function () {
            if (!(await validateCurrentStep())) {
                return;
            }

            payButton.disabled = true;
            payButton.textContent = 'Authenticating...';

            Accept.dispatchData(
                {
                    authData: {
                        clientKey: '{{authorizeClientKey}}',
                        apiLoginID: '{{authorizeApiLoginID}}'
                    },
                    cardData: {
                        cardNumber: document.getElementById('cardNumber').value,
                        month: document.getElementById('expMonth').value,
                        year: document.getElementById('expYear').value,
                        cardCode: document.getElementById('cardCode').value
                    }
                },
                function (response) {
                    if (response.messages.resultCode === 'Error') {
                        alert(response.messages.message.map(function (message) {
                            return message.text;
                        }).join('\n'));
                        payButton.disabled = false;
                        payButton.textContent = 'Start Secure Payment';
                        return;
                    }

                    document.getElementById('dataDescriptor').value = response.opaqueData.dataDescriptor;
                    document.getElementById('dataValue').value = response.opaqueData.dataValue;
                    form.submit();
                }
            );
        });

        Array.prototype.forEach.call(planRadios, function (radio) {
            radio.addEventListener('change', function () {
                syncPlanSelection(radio.value);
            });
        });

        Array.prototype.forEach.call(planPreviewCards, function (previewCard) {
            previewCard.addEventListener('click', function () {
                var selectedPlan = previewCard.getAttribute('data-plan-preview');
                var matchingRadio = document.querySelector('.plan-card input[type="radio"][value="' + selectedPlan + '"]');

                if (!matchingRadio) {
                    return;
                }

                matchingRadio.checked = true;
                syncPlanSelection(selectedPlan);
            });
        });

        usernameInput.addEventListener('input', function () {
            var username = normalizeUsername(usernameInput.value);
            usernameInput.value = username;
            updateUsernameViews(username);
            usernameStatus = { value: username, available: false };
            setUsernameMessage('', '');
        });

        usernameInput.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                checkUsernameAvailability();
            }
        });

        recheckUsernameBtn.addEventListener('click', checkUsernameAvailability);

        ['cardNumber', 'expMonth', 'expYear', 'cardCode'].forEach(function (id) {
            var input = document.getElementById(id);
            if (!input) {
                return;
            }

            input.addEventListener('input', function () {
                if (id === 'cardNumber') {
                    sanitizeNumericInput(input, 19);
                } else if (id === 'expMonth') {
                    sanitizeNumericInput(input, 2);
                } else if (id === 'expYear') {
                    sanitizeNumericInput(input, 4);
                } else {
                    sanitizeNumericInput(input, 4);
                }
                setPaymentFieldError('');
            });
        });

        ['password', 'password2', 'billingEmail', 'recoveryEmail'].forEach(function (name) {
            var input = form.querySelector('input[name="' + name + '"]');
            if (!input) {
                return;
            }

            input.addEventListener('input', function () {
                input.setCustomValidity('');
            });
        });

        updateUsernameViews(usernameStatus.value);

        if (serverErrors.requestedUsername) {
            setUsernameMessage(serverErrors.requestedUsername, 'error');
        }

        var initiallySelectedPlan = document.querySelector('.plan-card input[type="radio"]:checked');
        if (initiallySelectedPlan) {
            syncPlanSelection(initiallySelectedPlan.value);
        }
        showStep(getInitialStepFromErrors());
    }());
</script>

<style>
    .checkout-alert {
        margin-bottom: 18px;
        padding: 14px 16px;
        border-radius: 16px;
        font-weight: 600;
        line-height: 1.5;
    }

    .checkout-alert-danger {
        background: #fff1f1;
        color: #9b1c1c;
        border: 1px solid rgba(220, 38, 38, 0.18);
        box-shadow: 0 10px 28px rgba(185, 28, 28, 0.08);
    }

    .checkout-shell {
        min-height: calc(100vh - 85px);
        display: grid;
        grid-template-columns: 420px minmax(0, 1fr);
        background: linear-gradient(180deg, #edf4fb 0%, #ffffff 100%);
    }

    .field-error {
        border-color: #dc4c64 !important;
        box-shadow: 0 0 0 4px rgba(220, 76, 100, 0.12) !important;
        background: #fff8f9;
    }

    .checkout-aside {
        background: radial-gradient(circle at top, #1c3d70, #081629 58%);
        color: #fff;
        padding: 60px 48px;
    }

    .sidebar-identity {
        margin: 18px 0 14px;
    }

    .sidebar-label {
        display: inline-block;
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(223, 242, 255, 0.72);
    }

    .checkout-aside h1 {
        margin: 0;
        max-width: 100%;
        font-size: clamp(28px, 3vw, 38px);
        line-height: 1.12;
        font-weight: 900;
        letter-spacing: -1.5px;
        color: #ffffff;
    }

    #sidebarUsername {
        color: #dff2ff;
        display: inline-block;
        max-width: 100%;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .checkout-aside p {
        color: rgba(255, 255, 255, 0.75);
        font-size: 16px;
        line-height: 1.7;
    }

    .aside-chip {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .step-list {
        margin: 32px 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .step-item {
        display: flex;
        align-items: center;
