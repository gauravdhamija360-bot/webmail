<div class="container" style="padding:80px 0;max-width:700px;">

<div style="
background:white;
padding:50px;
border-radius:15px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
text-align:center;
">

<div style="
width:80px;
height:80px;
margin:auto;
border-radius:50%;
background:#e6f9f0;
display:flex;
align-items:center;
justify-content:center;
margin-bottom:20px;
">

<i class="fa fa-check" style="font-size:40px;color:#28a745;"></i>

</div>

<h2 style="font-weight:800;margin-bottom:10px;">
Payment Successful 🎉
</h2>

<p class="text-muted" style="margin-bottom:30px;">
Thank you <strong>{{customerName}}</strong>!  
{{#if subscriptionActive}}Your professional email account and billing profile have been created successfully.{{else}}Your payment has been received and your email setup is in progress.{{/if}}
</p>

<div style="
background:#f4f7f9;
padding:20px;
border-radius:10px;
margin-bottom:25px;
">

<h4 style="margin-bottom:5px;">
Your new email address
</h4>

<p style="
font-size:20px;
font-weight:700;
color:#6772e5;
margin:0;
">
{{newEmail}}
</p>

</div>

{{#if selectedPlan}}
<div style="
background:#eef5ff;
padding:20px;
border-radius:10px;
margin-bottom:25px;
text-align:left;
">
<h4 style="margin:0 0 10px;">Subscription Details</h4>
<p style="margin:0 0 8px;"><strong>Plan:</strong> {{selectedPlan}}</p>
<p style="margin:0 0 8px;"><strong>Status:</strong> {{#if subscriptionStatus}}{{subscriptionStatus}}{{else}}pending_activation{{/if}}</p>
<p style="margin:0;"><strong>Next Billing:</strong> {{#if nextBillingAt}}{{nextBillingAt}}{{else}}Will be scheduled after activation{{/if}}</p>
</div>
{{/if}}

{{#unless subscriptionActive}}
<div style="
background:#fff8e8;
padding:18px 20px;
border-radius:10px;
margin-bottom:25px;
text-align:left;
border:1px solid #f0d48a;
">
<strong style="display:block;margin-bottom:6px;">Sandbox sync still in progress</strong>
<p style="margin:0;color:#6b5a2b;">Your initial payment has gone through. Authorize.Net sandbox can take a little time before the recurring subscription record becomes available.</p>
</div>
{{/unless}}

<a href="/account/login" class="btn btn-primary" style="
padding:12px 30px;
font-weight:700;
border-radius:8px;
background:#6772e5;
border:none;
">

Go to Webmail Login

</a>

</div>

</div>
