<div class="container" style="padding:80px 0;max-width:700px;">

<div style="
background:white;
padding:50px;
border-radius:15px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
text-align:center;
">

<div style="
width:80px;
height:80px;
margin:auto;
border-radius:50%;
background:#e6f9f0;
display:flex;
align-items:center;
justify-content:center;
margin-bottom:20px;
">

<i class="fa fa-check" style="font-size:40px;color:#28a745;"></i>

</div>

<h2 style="font-weight:800;margin-bottom:10px;">
Payment Successful 🎉
</h2>

<p class="text-muted" style="margin-bottom:30px;">
Thank you <strong>{{customerName}}</strong>!  
Your professional email account has been created.
</p>

<div style="
background:#f4f7f9;
padding:20px;
border-radius:10px;
margin-bottom:25px;
">

<h4 style="margin-bottom:5px;">
Your new email address
</h4>

<p style="
font-size:20px;
font-weight:700;
color:#6772e5;
margin:0;
">
{{newEmail}}
</p>

</div>

<a href="/account/login" class="btn btn-primary" style="
padding:12px 30px;
font-weight:700;
border-radius:8px;
background:#6772e5;
border:none;
">

Go to Webmail Login

</a>

</div>

</div>