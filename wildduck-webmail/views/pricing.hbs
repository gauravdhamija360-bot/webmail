<div class="pricing-page-shell">
    <section class="pricing-hero">
        <div class="container pricing-hero-inner">
            <div>
                <div class="pricing-kicker">Live Plan Catalog</div>
                <h1>Choose the Yoover plan that fits how you want to bill.</h1>
                <p>
                    These subscription plans come directly from the same pricing catalog used in checkout, so what you see here is exactly what customers can buy.
                </p>
            </div>
            <div class="pricing-hero-card">
                <strong>Mailbox domain</strong>
                <span>@{{serviceDomain}}</span>
                <small>Secure webmail, mobile-friendly setup, and recurring billing visibility in one flow.</small>
            </div>
        </div>
    </section>

    <section class="pricing-content">
        <div class="container">
            <div class="pricing-page-grid">
                {{#if plans.length}}
                    {{#each plans}}
                        <article class="pricing-page-card {{#if featured}}is-featured{{/if}}">
                            <div class="pricing-page-card-top">
                                {{#if highlightTag}}<span class="pricing-page-tag">{{highlightTag}}</span>{{/if}}
                                <h2>{{name}}</h2>
                                <div class="pricing-page-price">
                                    <strong>{{formattedPrice}}</strong>
                                    <span>/ {{billingLabel}}</span>
                                </div>
                                <p>{{summary}}</p>
                            </div>

                            {{#if benefits.length}}
                                <ul class="pricing-page-benefits">
                                    {{#each benefits}}
                                        <li><span class="glyphicon glyphicon-ok"></span>{{this}}</li>
                                    {{/each}}
                                </ul>
                            {{/if}}

                            <div class="pricing-page-actions">
                                <a href="/purchase/{{code}}" class="pricing-page-btn {{#if featured}}primary{{else}}secondary{{/if}}" data-analytics-event="start_checkout" data-analytics-category="conversion" data-analytics-label="pricing_plan_{{code}}">Choose {{name}}</a>
                            </div>
                        </article>
                    {{/each}}
                {{else}}
                    <article class="pricing-page-card">
                        <div class="pricing-page-card-top">
                            <h2>Plans are being refreshed</h2>
                            <p>The live pricing catalog is not available right now. Please check again shortly.</p>
                        </div>
                        <div class="pricing-page-actions">
                            <a href="/" class="pricing-page-btn secondary" data-analytics-event="return_home" data-analytics-category="engagement" data-analytics-label="pricing_return_home">Return Home</a>
                        </div>
                    </article>
                {{/if}}
            </div>
        </div>
    </section>
</div>

<style>
    .pricing-page-shell {
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.08), transparent 35%),
            radial-gradient(circle at top right, rgba(14, 165, 233, 0.08), transparent 28%),
            #f5f9fb;
        min-height: 100vh;
    }

    .pricing-hero {
        padding: 96px 0 40px;
    }

    .pricing-hero-inner {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(280px, 360px);
        gap: 28px;
        align-items: end;
    }

    .pricing-kicker {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.12);
        color: #0f766e;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .pricing-hero h1 {
        margin: 16px 0 14px;
        font-size: clamp(38px, 6vw, 64px);
        line-height: 1;
        font-weight: 900;
        letter-spacing: -0.04em;
        color: #10212e;
    }

    .pricing-hero p {
        max-width: 760px;
        font-size: 18px;
        line-height: 1.7;
        color: #4a6071;
    }

    .pricing-hero-card {
        display: grid;
        gap: 8px;
        padding: 28px;
        border-radius: 28px;
        background: linear-gradient(160deg, #0f172a 0%, #124155 100%);
        color: #e5f4f7;
        box-shadow: 0 22px 60px rgba(15, 23, 42, 0.18);
    }

    .pricing-hero-card span {
        font-size: 28px;
        font-weight: 800;
    }

    .pricing-hero-card small {
        color: rgba(229, 244, 247, 0.78);
        line-height: 1.7;
    }

    .pricing-content {
        padding: 20px 0 88px;
    }

    .pricing-page-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
    }

    .pricing-page-card {
        display: grid;
        gap: 24px;
        padding: 30px;
        border-radius: 30px;
        border: 1px solid rgba(142, 166, 182, 0.35);
        background: rgba(255, 255, 255, 0.86);
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
    }

    .pricing-page-card.is-featured {
        border-color: rgba(15, 118, 110, 0.35);
        background: linear-gradient(180deg, rgba(240, 253, 250, 0.96) 0%, rgba(255, 255, 255, 0.98) 100%);
        transform: translateY(-6px);
    }

    .pricing-page-card-top {
        display: grid;
        gap: 12px;
    }

    .pricing-page-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
