        border-radius: 999px;
        background: #0f766e;
        color: #fff;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-page-card h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #10212e;
    }

    .pricing-page-price {
        display: flex;
        align-items: baseline;
        gap: 10px;
        flex-wrap: wrap;
    }

    .pricing-page-price strong {
        font-size: 40px;
        line-height: 1;
        letter-spacing: -0.04em;
        color: #10212e;
    }

    .pricing-page-price span,
    .pricing-page-card p,
    .pricing-page-benefits li {
        color: #566b7c;
    }

    .pricing-page-card p {
        margin: 0;
        line-height: 1.7;
    }

    .pricing-page-benefits {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 12px;
    }

    .pricing-page-benefits li {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        line-height: 1.6;
    }

    .pricing-page-benefits span {
        color: #0f766e;
        margin-top: 3px;
    }

    .pricing-page-actions {
        margin-top: auto;
    }

    .pricing-page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 52px;
