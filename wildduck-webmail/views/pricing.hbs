        border: 1px solid #cfe0ea;
    }

    .pricing-page-btn:hover {
        text-decoration: none;
        transform: translateY(-1px);
    }

    @media (max-width: 900px) {
        .pricing-hero {
            padding-top: 72px;
        }

        .pricing-hero-inner {
            grid-template-columns: 1fr;
        }
    }
</style>
